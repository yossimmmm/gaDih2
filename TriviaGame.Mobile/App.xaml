<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TriviaGame.Mobile"
             x:Class="TriviaGame.Mobile.App">
    <Application.Resources>
        <!-- כאן רושמים את כל המשאבים המשותפים של האפליקציה:
             צבעים, styles, ופונטים שזמינים בכל המסכים. -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- צבעי המערכת של האפליקציה. -->
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <!-- הגדרות הסגנון הכלליות: פינות, כפתורים, טקסט, וריווחים. -->
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
