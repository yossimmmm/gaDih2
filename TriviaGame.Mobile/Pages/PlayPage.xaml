<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TriviaGame.Mobile.Pages.PlayPage"
             Title="Play">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="Play" FontSize="32" FontAttributes="Bold" />

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <ActivityIndicator x:Name="BusyIndicator"
                                   IsRunning="False"
                                   IsVisible="False"
                                   VerticalOptions="Center" />
                <Label x:Name="StatusLabel"
                       Grid.Column="1"
                       Text="Status: ready"
                       LineBreakMode="WordWrap" />
            </Grid>

            <Border Stroke="#8E7CC3" Padding="14" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="RoomLabel" Text="Room: none" LineBreakMode="WordWrap" />
                    <Entry x:Name="QuestionCountEntry" Placeholder="Question count" Keyboard="Numeric" Text="10" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="Start Game" Clicked="OnStartGameClicked" />
                        <Button Grid.Column="1" Text="Load Question" Clicked="OnLoadQuestionClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="#8E7CC3" Padding="14" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Question" FontSize="20" FontAttributes="Bold" />
                    <Label x:Name="QuestionLabel" Text="Question: -" LineBreakMode="WordWrap" />
                    <Label x:Name="TimerLabel" Text="Time limit: -" />
                    <CollectionView x:Name="OptionsView"
                                    HeightRequest="230"
                                    SelectionMode="Single"
                                    SelectionChanged="OnOptionSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="#5F5A72" Padding="10" Margin="0,4" StrokeShape="RoundRectangle 6">
                                    <Label Text="{Binding OptionText}" LineBreakMode="WordWrap" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Button Text="Submit Answer" Clicked="OnSubmitAnswerClicked" />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="#8E7CC3" Padding="14" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="Load Scoreboard" Clicked="OnLoadScoreboardClicked" />
                        <Button Grid.Column="1" Text="Stats" Clicked="OnStatsClicked" />
                    </Grid>
                    <Label x:Name="ScoreboardLabel" Text="Scoreboard: -" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
