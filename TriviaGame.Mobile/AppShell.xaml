<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TriviaGame.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:TriviaGame.Mobile"
    Title="Trivia Game">

    <!-- ה-Shell הוא הקונטיינר הראשי של האפליקציה.
         כרגע יש בו רק מסך אחד, אבל המבנה הזה מאפשר להוסיף ניווט בעתיד. -->
    <ShellContent
        Title="Game"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>
