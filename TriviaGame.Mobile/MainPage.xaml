<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TriviaGame.Mobile.MainPage"
             Title="Trivia Mobile API Client">
    <ScrollView>
        <!-- כל המסך עטוף ב-ScrollView כדי שכל האזורים יהיו נגישים גם במסך צר. -->
        <VerticalStackLayout Padding="12" Spacing="10">
            <!-- כותרת עליונה שמבהירה שזה לקוח API של טריוויה ולא משחק עצמו. -->
            <Label Text="Trivia Mobile API Client"
                   FontSize="22"
                   FontAttributes="Bold" />

            <!-- סטטוס הפעולה מוצג בראש המסך כדי שכל לחיצה תיתן משוב מידי. -->
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <ActivityIndicator x:Name="BusyIndicator"
                                   Grid.Column="0"
                                   IsRunning="False"
                                   IsVisible="False"
                                   VerticalOptions="Center" />
                <Label x:Name="StatusLabel"
                       Grid.Column="1"
                       Text="Status: ready"
                       VerticalOptions="Center"
                       LineBreakMode="WordWrap" />
            </Grid>

            <!-- אזור הגדרות API:
                 כאן בוחרים סביבה, כתובת למכשיר פיזי, או override ידני לשרת. -->
            <Border Stroke="#D0D0D0" Padding="10" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="API Environment" FontAttributes="Bold" />

                    <!-- בחירת environment נשמרת ב-Preferences ומשפיעה על ה-base URL. -->
                    <Picker x:Name="EnvironmentPicker" SelectedIndexChanged="OnEnvironmentChanged">
                        <Picker.Items>
                            <x:String>Development</x:String>
                            <x:String>Staging</x:String>
                            <x:String>Production</x:String>
                        </Picker.Items>
                    </Picker>

                    <!-- כתובת למכשיר פיזי.
                         משתמשים בה אם האפליקציה רצה על טלפון אמיתי ולא על emulator. -->
                    <Entry x:Name="DeviceBaseUrlEntry" Placeholder="Device URL (for physical phone)" />

                    <!-- override ידני, אם רוצים לכוון את הלקוח לשרת אחר בלי לשנות את שאר ההגדרות. -->
                    <Entry x:Name="OverrideBaseUrlEntry" Placeholder="Optional override URL" />

                    <!-- שומר את ההגדרות ומחשב מחדש את ה-base URL בפועל. -->
                    <Button Text="Apply API Settings" Clicked="OnApplyApiSettingsClicked" />

                    <!-- תצוגה בלבד שמראה לאיזה URL הלקוח פונה בפועל. -->
                    <Label x:Name="ResolvedBaseUrlLabel" Text="Base URL: -" FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <!-- אזור Auth:
                 login/register/profile בלבד, כדי לא לערבב איפוס סיסמה עם התחברות רגילה. -->
            <Border Stroke="#D0D0D0" Padding="10" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Auth" FontAttributes="Bold" FontSize="18" />

                    <Label Text="Email" FontSize="12" />
                    <Entry x:Name="EmailEntry" Placeholder="email@example.com" Keyboard="Email" />

                    <Label Text="Password" FontSize="12" />
                    <Entry x:Name="PasswordEntry" Placeholder="Password for login/register" IsPassword="True" />

                    <Label Text="Username" FontSize="12" />
                    <Entry x:Name="UsernameEntry" Placeholder="Only needed for register/profile" />

                    <Label Text="Full name" FontSize="12" />
                    <Entry x:Name="FullNameEntry" Placeholder="Only needed for register/profile" />

                    <!-- כפתורי auth בסיסיים. -->
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Login" Clicked="OnLoginClicked" />
                        <Button Text="Register" Clicked="OnRegisterClicked" />
                        <Button Text="Logout" Clicked="OnLogoutClicked" />
                    </HorizontalStackLayout>

                    <!-- פעולות נוספות על פרופיל המשתמש. -->
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Load Me" Clicked="OnLoadMeClicked" />
                        <Button Text="Update Profile" Clicked="OnUpdateProfileClicked" />
                    </HorizontalStackLayout>

                    <!-- מציג את מצב ההתחברות הנוכחי. -->
                    <Label x:Name="AuthStateLabel" Text="Auth: not loaded" />
                </VerticalStackLayout>
            </Border>

            <!-- #forgot-password #reset-password
                 אזור נפרד לשחזור סיסמה:
                 1. שולחים מייל איפוס.
                 2. מדביקים את הקישור/הטוקן מהמייל.
                 3. בוחרים סיסמה חדשה. -->
            <Border Stroke="#D0D0D0" Padding="10" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Password Recovery" FontAttributes="Bold" FontSize="18" />

                    <Label Text="1. Send reset email" FontAttributes="Bold" FontSize="13" />
                    <Label Text="Enter the account email, then press Send Reset Email." FontSize="12" />
                    <Entry x:Name="ForgotEmailEntry"
                           Placeholder="email@example.com"
                           Keyboard="Email" />
                    <Button Text="Send Reset Email"
                            Clicked="OnForgotPasswordClicked"
                            HorizontalOptions="Start" />

                    <BoxView HeightRequest="1" Color="#3A3A3A" Margin="0,8" />

                    <Label Text="2. Paste link or token" FontAttributes="Bold" FontSize="13" />
                    <Label Text="Copy the reset link from the email and paste it here. Token only also works." FontSize="12" />
                    <Entry x:Name="ResetTokenEntry"
                           Placeholder="Paste reset link or token from email" />

                    <Label Text="3. Choose new password" FontAttributes="Bold" FontSize="13" />
                    <Entry x:Name="NewPasswordEntry"
                           Placeholder="New password"
                           IsPassword="True" />
                    <Button Text="Reset Password"
                            Clicked="OnResetPasswordClicked"
                            HorizontalOptions="Start" />

                    <Label x:Name="PasswordRecoveryLabel"
                           Text="Password recovery: ready"
                           FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <!-- אזור חדרים:
                 יצירת חדר, הצטרפות, טעינת חדרים ציבוריים, וטעינת שחקנים. -->
            <Border Stroke="#D0D0D0" Padding="10" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Rooms" FontAttributes="Bold" />

                    <!-- כפתור לטעינת סוגי שאלות כדי למלא את ה-picker של יצירת החדר. -->
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Load Question Types" Clicked="OnLoadQuestionTypesClicked" />
                        <Picker x:Name="QuestionTypePicker" WidthRequest="160" />
                    </HorizontalStackLayout>

                    <!-- שם החדר שנשלח לשרת בזמן יצירת חדר חדש. -->
                    <Entry x:Name="RoomNameEntry" Placeholder="Room name" />

                    <!-- בחירה אם החדר ציבורי או פרטי. -->
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="Public" VerticalOptions="Center" />
                        <Switch x:Name="IsPublicSwitch" />
                        <Button Text="Create Room" Clicked="OnCreateRoomClicked" />
                    </HorizontalStackLayout>

                    <!-- תוצאה מקומית לפעולות החדר, כולל קוד החדר שנוצר. -->
                    <Label x:Name="RoomStatusLabel"
                           Text="Rooms: ready"
                           LineBreakMode="WordWrap" />

                    <!-- קוד חדר וכינוי להצטרפות. -->
                    <Entry x:Name="RoomCodeEntry" Placeholder="Room code (e.g. ABC123)" />
                    <Entry x:Name="NicknameEntry" Placeholder="Nickname for room" />

                    <!-- פעולות על חדרים ושחקנים. -->
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Load Public Rooms" Clicked="OnLoadPublicRoomsClicked" />
                        <Button Text="Join Room" Clicked="OnJoinRoomClicked" />
                        <Button Text="Load Players" Clicked="OnLoadPlayersClicked" />
                    </HorizontalStackLayout>

                    <!-- שמות השחקנים שהשרת החזיר עבור החדר הנוכחי. -->
                    <Label x:Name="PlayersLabel"
                           Text="Players: -"
                           LineBreakMode="WordWrap" />

                    <!-- רשימת החדרים הציבוריים שהגיעה מהשרת. -->
                    <CollectionView x:Name="PublicRoomsView"
                                    HeightRequest="160"
                                    SelectionMode="Single"
                                    SelectionChanged="OnPublicRoomSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" Padding="4">
                                    <Label Text="{Binding RoomName}" Grid.Column="0" />
                                    <Label Text="{Binding RoomCode}" Grid.Column="1" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- אזור המשחק:
                 התחלת משחק, טעינת שאלה, שליחת תשובה, וצפייה ב-scoreboard. -->
            <Border Stroke="#D0D0D0" Padding="10" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Game" FontAttributes="Bold" />
                    <Label x:Name="ActiveRoomLabel"
                           Text="Active room: none"
                           LineBreakMode="WordWrap" />
                    <Entry x:Name="QuestionCountEntry" Placeholder="Question count (default 10)" Keyboard="Numeric" />

                    <!-- התחלת משחק או טעינת השאלה הנוכחית. -->
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Start Game" Clicked="OnStartGameClicked" />
                        <Button Text="Load Current Question" Clicked="OnLoadCurrentQuestionClicked" />
                    </HorizontalStackLayout>

                    <!-- הטקסט המלא של השאלה הנוכחית. -->
                    <Label x:Name="QuestionTextLabel" Text="Question: -" />
                    <Label x:Name="GameStatusLabel"
                           Text="Game: create or join a room first."
                           LineBreakMode="WordWrap" />

                    <!-- רשימת אפשרויות התשובה לבחירה. -->
                    <CollectionView x:Name="OptionsView"
                                    HeightRequest="160"
                                    SelectionMode="Single"
                                    SelectionChanged="OnOptionSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="#666666"
                                        Padding="10"
                                        Margin="0,3"
                                        StrokeShape="RoundRectangle 6">
                                    <Label Text="{Binding OptionText}" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- שליחת תשובה לשרת וטעינת scoreboard. -->
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Submit Answer" Clicked="OnSubmitAnswerClicked" />
                        <Button Text="Load Scoreboard" Clicked="OnLoadScoreboardClicked" />
                    </HorizontalStackLayout>

                    <!-- תצוגה טקסטואלית פשוטה של ה-scoreboard. -->
                    <Label x:Name="ScoreboardLabel" Text="Scoreboard: -" />
                </VerticalStackLayout>
            </Border>

            <!-- אזור סטטיסטיקות ועוזר:
                 כאן רואים סטטיסטיקות אישיות, top players, ושאלות ל-assistant. -->
            <Border Stroke="#D0D0D0" Padding="10" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Stats + Assistant" FontAttributes="Bold" />

                    <!-- כפתורים לטעינת סטטיסטיקות אישיות ולצפייה בשחקנים מובילים. -->
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Load My Stats" Clicked="OnLoadStatsClicked" />
                        <Button Text="Top Players" Clicked="OnLoadTopPlayersClicked" />
                    </HorizontalStackLayout>

                    <!-- כאן מוצגים או הסטטיסטיקות האישיות או סיכום של top players. -->
                    <Label x:Name="StatsLabel" Text="Stats: -" />

                    <!-- שדה טקסט שממנו שולחים שאלה ל-assistant endpoint. -->
                    <Entry x:Name="AssistantPromptEntry" Placeholder="Ask assistant..." />

                    <!-- כפתור לשליחת שאלה לעוזר וקבלת תשובה. -->
                    <Button Text="Ask Assistant" Clicked="OnAskAssistantClicked" />

                    <!-- התשובה שמגיעה מהעוזר. -->
                    <Label x:Name="AssistantResponseLabel" Text="Assistant: -" />
                </VerticalStackLayout>
            </Border>

            <!-- אינדיקטור טעינה והודעת סטטוס כללית לכל המסך. -->
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
