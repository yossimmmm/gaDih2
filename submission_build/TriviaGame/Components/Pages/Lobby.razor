@page "/lobby/{RoomCode}"
@inherits AuthPageBase
@using Models
@using DBL
@using System.Threading
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@rendermode InteractiveServer

<style>
    .wrap {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 25%, #fecfef 50%, #fad0c4 75%, #ffd1ff 100%);
        background-attachment: fixed;
        color: #333;
        font-family: 'Comic Neue', cursive;
        position: relative;
        overflow: hidden;
        padding: 20px;
    }
    
    .wrap::before {
        content: "🎮";
        position: absolute;
        font-size: 4em;
        animation: float 3s ease-in-out infinite;
        top: 5%;
        left: 5%;
        opacity: 0.6;
    }
    
    .wrap::after {
        content: "👥";
        position: absolute;
        font-size: 3em;
        animation: float 4s ease-in-out infinite reverse;
        top: 10%;
        right: 8%;
        opacity: 0.5;
    }

    .card {
        width: 600px;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 240, 245, 0.95) 100%);
        border: 5px solid #ff69b4;
        border-radius: 35px;
        padding: 40px;
        box-shadow: 0 15px 40px rgba(255, 20, 147, 0.4), 0 0 60px rgba(255, 182, 193, 0.3);
        backdrop-filter: blur(10px);
        position: relative;
        z-index: 1;
        animation: pulse-glow 3s ease-in-out infinite;
        transform-style: preserve-3d;
    }
    
    .card::before {
        content: "🏁";
        position: absolute;
        top: -25px;
        left: -25px;
        font-size: 4em;
        animation: bounce 2s infinite;
        z-index: -1;
    }

    .title {
        font-size: 2.3rem;
        font-family: 'Fredoka One', cursive;
        color: #ff1493;
        text-shadow: 3px 3px 0px #ff69b4, 6px 6px 10px rgba(255, 20, 147, 0.4);
        margin-bottom: 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
        animation: float 2s ease-in-out infinite;
    }

    .sub {
        margin-bottom: 25px;
        opacity: 0.8;
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.1em;
        color: #666;
        text-align: center;
        padding: 10px;
        background: rgba(255, 182, 193, 0.2);
        border-radius: 15px;
    }

    .btn {
        padding: 15px 25px;
        border-radius: 25px;
        border: 4px solid #ff1493;
        cursor: pointer;
        font-family: 'Fredoka One', cursive;
        font-weight: 800;
        font-size: 1.2em;
        background: linear-gradient(135deg, #ff6b9d 0%, #ff8fab 50%, #ffa8c5 100%);
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 2px;
        box-shadow: 0 8px 20px rgba(255, 20, 147, 0.4);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }
    
    .btn::before {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.3);
        transform: translate(-50%, -50%);
        transition: width 0.6s, height 0.6s;
    }
    
    .btn:hover::before {
        width: 300px;
        height: 300px;
    }
    
    .btn:hover {
        transform: translateY(-5px) scale(1.05);
        box-shadow: 0 12px 30px rgba(255, 20, 147, 0.6);
        animation: bounce 0.6s ease;
    }

    .btn2 {
        padding: 15px 25px;
        border-radius: 25px;
        border: 4px solid #ffb6c1;
        cursor: pointer;
        font-family: 'Fredoka One', cursive;
        font-weight: 800;
        font-size: 1.2em;
        background: rgba(255, 182, 193, 0.3);
        color: #ff1493;
        text-transform: uppercase;
        letter-spacing: 2px;
        box-shadow: 0 5px 15px rgba(255, 182, 193, 0.4);
        transition: all 0.3s ease;
    }
    
    .btn2:hover {
        transform: translateY(-3px) scale(1.03);
        box-shadow: 0 8px 25px rgba(255, 182, 193, 0.6);
        border-color: #ff1493;
        background: rgba(255, 182, 193, 0.5);
    }

    .list {
        margin-top: 20px;
        border-top: 3px dashed rgba(255, 20, 147, 0.4);
        padding-top: 20px;
        background: rgba(255, 240, 245, 0.5);
        border-radius: 20px;
        padding: 20px;
    }

    .row {
        display: flex;
        justify-content: space-between;
        padding: 15px;
        margin: 10px 0;
        border-bottom: 2px solid rgba(255, 182, 193, 0.3);
        background: rgba(255, 255, 255, 0.7);
        border-radius: 15px;
        transition: all 0.3s ease;
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.1em;
        color: #333;
    }
    
    .row:hover {
        transform: translateX(10px) scale(1.02);
        box-shadow: 0 5px 15px rgba(255, 182, 193, 0.4);
        background: rgba(255, 255, 255, 0.9);
    }

    .badge {
        font-size: 1em;
        opacity: 0.9;
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        color: #ff1493;
        padding: 5px 10px;
        background: rgba(255, 182, 193, 0.3);
        border-radius: 10px;
    }

    .err {
        color: #ff4757;
        margin-top: 15px;
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.1em;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
        animation: wiggle 0.5s ease;
        padding: 10px;
        background: rgba(255, 71, 87, 0.1);
        border-radius: 15px;
        border: 2px solid #ff4757;
    }
</style>

@* אם המשתמש עדיין לא מזוהה, מציגים טעינה בלבד *@
@if (Session.CurrentUserId is null)
{
    <div class="wrap"><div class="card">Loading...</div></div>
}
else
{
    @* מעטפת דף הלובי *@
    <div class="wrap">
        <div class="card">
            @* כותרת לובי, כולל קוד חדר ותג Host *@
            <div class="title">
                <span>🎮 Lobby</span>
                @if (IsHost)
                {
                    @* תג מיוחד למארח שמציג את קוד החדר *@
                    <span class="badge">Room Code: @RoomCode</span>
                }
                @* תג קבוע עם קוד חדר לכל המשתתפים *@
                <span class="badge">Room: @RoomCode</span>
            </div>

            @* שם החדר כפי שהוגדר בעת היצירה *@
            <div class="sub">@RoomName</div>

            @* אזור פעולות: חזרה לתפריט + התחלת משחק למארח בלבד *@
            <div>
                @* כפתור Back: חזרה לתפריט ראשי *@
                <button class="btn2" @onclick="@(() => Nav.NavigateTo("/menu", true))" title="Return to menu page">Back</button>
                @if (IsHost)
                {
                    @* כפתור Start Game: זמין רק למארח, מפעיל בחירת שאלות ושידור התחלת משחק *@
                    <button class="btn" style="margin-left:8px" @onclick="StartGameAsync" title="Host starts game for all room players">Start Game</button>
                }
            </div>

            @* רשימת השחקנים שנמצאים כרגע בחדר *@
            <div class="list">
                @if (Players.Count == 0)
                {
                    <div class="badge">No players yet...</div>
                }
                else
                {
                    @foreach (var p in Players)
                    {
                        <div class="row">
                            <div>@p.Nickname</div>
                            <div class="badge">User: @p.UserID @((p.UserID == HostId) ? "(Host)" : "")</div>
                        </div>
                    }
                }
            </div>

            @* תיבת הודעת סטטוס/שגיאה *@
            @if (!string.IsNullOrWhiteSpace(Status))
            {
                <div class="err">@Status</div>
            }

        </div>
    </div>
}

@code {
    // הסבר עמוד: לובי חדר לפני התחלת משחק, כולל שחקנים ועדכוני זמן אמת.

    // קוד חדר שמגיע מה-URL.
    [Parameter] public string RoomCode { get; set; } = "";

    // שם החדר להצגה.
    private string RoomName = "";
    // מזהה חדר פנימי במסד.
    private int RoomId = 0;
    // מזהה המארח של החדר.
    private int HostId = 0;
    // בדיקה האם המשתמש הנוכחי הוא המארח.
    private bool IsHost => Session.CurrentUserId.HasValue && Session.CurrentUserId.Value == HostId;

    // הודעת שגיאה/סטטוס להצגה במסך.
    private string Status = "";
    // רשימת שחקנים עדכנית בחדר.
    private List<RoomPlayer> Players = new();
    // מונע אתחול כפול של הדף.
    private bool Loaded = false;

    // גישת DB לטבלאות חדרים/משתתפים.
    private readonly RoomDB roomDB = new();
    // גישת DB למשחק (בחירת שאלות לפתיחת משחק).
    private readonly GameDB gameDB = new();

    // חיבור SignalR להאזנה ושידור אירועי לובי.
    private HubConnection? hub;
    // טיימר heartbeat שמעדכן שהחדר עדיין פעיל.
    private System.Threading.Timer? heartbeatTimer;
    private bool _disposing = false;

    // אתחול ראשי לאחר אימות משתמש.
    protected override async Task OnAuthedAsync()
    {
        // הגנה: אל תריץ אתחול פעמיים.
        if (Loaded)
            return;
        Loaded = true;

        // מביאים חדר לפי RoomCode מה-URL.
        var room = await roomDB.GetRoomByCodeAsync(RoomCode.Trim().ToUpperInvariant());
        if (room is null)
        {
            Status = "Room not found.";
            return;
        }

        // שומרים נתוני חדר לשימוש פנימי ותצוגה.
        RoomId = room.RoomID;
        HostId = room.HostID;
        RoomName = room.RoomName;

        // טעינת שחקנים התחלתית.
        await LoadPlayersAsync();

        // בניית חיבור ל-hub של המשחק.
        hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/game"))
            .WithAutomaticReconnect()
            .Build();

        // אירוע: שחקן נכנס -> טוענים רשימת שחקנים מחדש ומרעננים UI.
        hub.On<string>("PlayerJoined", async _ =>
        {
            await LoadPlayersAsync();
            await InvokeAsync(StateHasChanged);
        });

        // אירוע: משחק התחיל -> ניווט למסך המשחק.
        hub.On<string>("GameStarted", async _ =>
        {
            await InvokeAsync(() => SafeNavigateTo($"/play/{RoomCode}", true));
            await Task.CompletedTask;
        });
        
        // אירוע: שחקן יצא -> רענון רשימת שחקנים.
        hub.On<string>("PlayerLeft", async _ =>
        {
            await LoadPlayersAsync();
            await InvokeAsync(StateHasChanged);
        });

        // אירוע: מארח סגר חדר -> הודעה וחזרה לתפריט.
        hub.On<string>("RoomClosed", async _ =>
        {
            Status = "Room closed by host.";
            await InvokeAsync(StateHasChanged);
            await Task.Delay(1200);
            await InvokeAsync(() => SafeNavigateTo("/menu", true));
        });

        // פתיחת החיבור בפועל.
        await hub.StartAsync();
        // הצטרפות לקבוצת SignalR של החדר כדי לקבל רק אירועי חדר זה.
        await hub.InvokeAsync("JoinRoomGroup", RoomCode, Session.CurrentUserId.Value);

        // heartbeat כל 10 שניות לשמירת פעילות החדר.
        heartbeatTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                if (hub is not null)
                    await hub.InvokeAsync("RoomHeartbeat", RoomCode);
            }
            catch { }
        }, null, 0, 10000);

        // משדרים לכל האחרים ששחקן נכנס כדי שירעננו את לובי החדר.
        await hub.InvokeAsync("PlayerJoined", RoomCode);
    }

    // טוען רשימת שחקנים עדכנית מהמסד.
    private async Task LoadPlayersAsync()
    {
        Players = await roomDB.GetPlayersAsync(RoomId);
    }

    // מופעל בלחיצה על Start Game (למארח בלבד).
    private async Task StartGameAsync()
    {
        // מאפסים סטטוס קודם.
        Status = "";

        // בדיקת הרשאה: רק מארח יכול להתחיל משחק.
        if (!IsHost)
        {
            Status = "Only host can start.";
            return;
        }

        // מכינים 10 שאלות לחדר.
        var inserted = await gameDB.PickQuestionsForRoomAsync(RoomId, 10);
        if (inserted <= 0)
        {
            Status = "No questions available. Add questions to DB first.";
            return;
        }

        // מודיעים לכל משתתפי החדר שהמשחק מתחיל.
        if (hub is not null)
            await hub.InvokeAsync("GameStarted", RoomCode);

        // ניווט מיידי למסך המשחק גם בצד המארח.
        SafeNavigateTo($"/play/{RoomCode}", true);
    }

    // ניקוי משאבים ביציאה מהעמוד.
    public async ValueTask DisposeAsync()
    {
        _disposing = true;
        // עוצרים heartbeat timer.
        heartbeatTimer?.Dispose();
        if (hub is not null)
        {
            // יוצאים מקבוצת החדר (best effort).
            try { await hub.InvokeAsync("LeaveRoomGroup", RoomCode); } catch { }
            // עוצרים חיבור Hub (best effort).
            try { await hub.StopAsync(); } catch { }
            // משחררים אובייקט Hub.
            await hub.DisposeAsync();
        }
    }

    private void SafeNavigateTo(string url, bool forceLoad)
    {
        if (_disposing)
            return;

        try
        {
            Nav.NavigateTo(url, forceLoad);
        }
        catch (JSDisconnectedException)
        {
            // Circuit disconnected while navigating; ignore during teardown.
        }
        catch (InvalidOperationException ex) when (ex.Message.Contains("disconnected", StringComparison.OrdinalIgnoreCase))
        {
            // Same scenario surfaced as InvalidOperationException in some flows.
        }
    }
}
