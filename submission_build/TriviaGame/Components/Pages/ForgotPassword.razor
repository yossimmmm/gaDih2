@page "/forgot-password"
@using Models
@inject IJSRuntime JS
@rendermode InteractiveServer

<style>
    .fp-wrap {
        max-width: 420px;
        margin: 80px auto;
        padding: 24px;
        border: 1px solid #ddd;
        border-radius: 12px;
        background: #fff;
    }

    .fp-input {
        width: 100%;
        padding: 10px;
        margin: 8px 0;
    }

    .fp-btn {
        width: 100%;
        padding: 10px;
    }

    .fp-status {
        margin-top: 10px;
        font-weight: 700;
    }

    .fp-status.success {
        color: #1b8f3a;
    }

    .fp-status.error {
        color: #c62828;
    }
</style>

@* מעטפת הדף שמרכזת את טופס שחזור הסיסמה *@
<div class="fp-wrap">
    @* כותרת ראשית של המסך *@
    <h3>Forgot Password</h3>
    @* טקסט קצר שמסביר למשתמש מה לעשות *@
    <p>Enter your email to get a reset link.</p>
    @* שדה אימייל: נקשר ל-Email ומתעדכן בכל הקלדה *@
    <input class="fp-input" @bind="Email" @bind:event="oninput" type="email" placeholder="Email" disabled="@IsLoading" />
    @* כפתור שליחה: מפעיל SendReset וננעל בזמן בקשה פעילה *@
    <button class="fp-btn" @onclick="SendReset" disabled="@IsLoading">Send Reset Link</button>
    @* מציגים סטטוס הצלחה/שגיאה רק אם יש הודעה *@
    @if (!string.IsNullOrWhiteSpace(Status))
    {
        @* צבע סטטוס לפי IsSuccess: ירוק=הצלחה, אדום=שגיאה *@
        <div class="fp-status @(IsSuccess ? "success" : "error")">@Status</div>
    }
    @* קישור חזרה למסך ההתחברות *@
    <div style="margin-top:12px"><a href="/login">Back to login</a></div>

</div>

@code {
    // הסבר עמוד: ניהול תהליך "שכחתי סיסמה" בצד לקוח.

    // האימייל שהמשתמש מקליד בטופס.
    private string Email = "";
    // הודעת סטטוס להצגה מתחת לכפתור.
    private string Status = "";
    // דגל מצב טעינה: true בזמן בקשת רשת פעילה.
    private bool IsLoading;
    // דגל מצב הצלחה: קובע את צבע הודעת הסטטוס.
    private bool IsSuccess;

    // פונקציה ראשית של כפתור השליחה.
    private async Task SendReset()
    {
        // איפוס הודעה קודמת לפני ניסיון חדש.
        Status = "";
        IsSuccess = false;

        // ולידציה בסיסית לפורמט אימייל לפני יציאה לרשת.
        if (!ValidationHelper.IsValidEmail(Email))
        {
            Status = "Enter a valid email.";
            return;
        }

        // נעילת UI בזמן בקשה כדי למנוע לחיצות כפולות.
        IsLoading = true;
        try
        {
            // קריאה לפונקציית JS שמבצעת fetch ל-endpoint של forgot-password.
            var res = await JS.InvokeAsync<ForgotResult>("auth.forgotPassword", Email.Trim().ToLowerInvariant());

            // אם השרת החזיר הצלחה.
            if (res.Ok)
            {
                // אם יש הודעה מהשרת מציגים אותה, אחרת הודעת ברירת מחדל.
                Status = string.IsNullOrWhiteSpace(res.Message)
                    ? "Reset email was sent successfully."
                    : res.Message;
                IsSuccess = true;
            }
            else
            {
                // במקרה כישלון: הודעת שרת או fallback כללי.
                Status = string.IsNullOrWhiteSpace(res.Message)
                    ? "Could not send reset email."
                    : res.Message;
                IsSuccess = false;
            }
        }
        catch
        {
            // טיפול בכשל רשת/JS לא צפוי.
            Status = "Could not send reset email right now.";
            IsSuccess = false;
        }
        finally
        {
            // שחרור מצב טעינה בכל תרחיש.
            IsLoading = false;
        }
    }

    // מודל תשובה מינימלי שמוחזר מה-JS.
    private sealed class ForgotResult
    {
        // מציין האם הקריאה הצליחה.
        public bool Ok { get; set; }
        // הודעה ידידותית להצגה למשתמש.
        public string Message { get; set; } = "";
    }
}
