@page "/rooms"
@inherits AuthPageBase
@using Models
@using DBL
@using Microsoft.AspNetCore.SignalR.Client
@rendermode InteractiveServer

@* KEYWORDS: rooms, public rooms, join room, groups, room code, play *@
@* הדף הזה מציג חדרים ציבוריים ומאפשר הצטרפות לפי קוד או לפי רשימה. *@

<style>
    .wrap {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 25%, #fecfef 50%, #fad0c4 75%, #ffd1ff 100%);
        background-attachment: fixed;
        color: #333;
        font-family: 'Comic Neue', cursive;
        position: relative;
        overflow: hidden;
        padding: 20px;
    }
    
    .wrap::before { content: "🏠"; position: absolute; font-size: 4em; animation: float 3s ease-in-out infinite; top: 5%; left: 5%; opacity: 0.6; }
    .wrap::after { content: "🚀"; position: absolute; font-size: 3em; animation: float 4s ease-in-out infinite reverse; top: 10%; right: 8%; opacity: 0.5; }

    .card {
        width: 500px;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 240, 245, 0.95) 100%);
        border: 5px solid #ff69b4;
        border-radius: 35px;
        padding: 40px;
        box-shadow: 0 15px 40px rgba(255, 20, 147, 0.4), 0 0 60px rgba(255, 182, 193, 0.3);
        backdrop-filter: blur(10px);
        position: relative;
        z-index: 1;
        animation: pulse-glow 3s ease-in-out infinite;
        transform-style: preserve-3d;
    }
    .card::before { content: "🎲"; position: absolute; top: -25px; right: -25px; font-size: 4em; animation: bounce 2s infinite; z-index: -1; }
    .title { font-size: 2.3rem; font-family: 'Fredoka One', cursive; color: #ff1493; text-shadow: 3px 3px 0 #ff69b4, 6px 6px 10px rgba(255,20,147,.4); margin-bottom: 15px; letter-spacing: 2px; animation: float 2s ease-in-out infinite; text-align: center; }
    .sub { margin-bottom: 25px; opacity: .8; font-family: 'Comic Neue', cursive; font-weight: 700; font-size: 1.1em; color: #666; text-align: center; }
    .in { width: 100%; padding: 15px 20px; margin: 12px 0; border-radius: 20px; border: 3px solid #ffb6c1; background: rgba(255,255,255,.9); color: #333; font-family: 'Comic Neue', cursive; font-weight: 700; font-size: 1.1em; transition: all .3s ease; box-shadow: inset 0 2px 5px rgba(0,0,0,.1); }
    .in:focus { outline: none; border-color: #ff1493; box-shadow: 0 0 20px rgba(255,20,147,.5), inset 0 2px 5px rgba(0,0,0,.1); transform: scale(1.02); background: #fff; }
    .in::placeholder { color: rgba(255,105,180,.6); font-weight: 700; }
    .btn { width: 100%; padding: 18px; margin: 10px 0; border-radius: 25px; border: 4px solid #ff1493; cursor: pointer; font-family: 'Fredoka One', cursive; font-weight: 700; font-size: 1.2em; background: linear-gradient(135deg,#ff6b9d 0%,#ff8fab 50%,#ffa8c5 100%); color: #fff; text-transform: uppercase; letter-spacing: 2px; box-shadow: 0 8px 20px rgba(255,20,147,.4); transition: all .3s ease; position: relative; overflow: hidden; }
    .btn::before { content: ""; position: absolute; top: 50%; left: 50%; width: 0; height: 0; border-radius: 50%; background: rgba(255,255,255,.3); transform: translate(-50%, -50%); transition: width .6s, height .6s; }
    .btn:hover::before { width: 400px; height: 400px; }
    .btn:hover { transform: translateY(-5px) scale(1.05); box-shadow: 0 12px 30px rgba(255,20,147,.6); animation: bounce .6s ease; }
    .btn2 { width: 100%; padding: 18px; margin: 10px 0; border-radius: 25px; border: 4px solid #ffb6c1; cursor: pointer; font-family: 'Fredoka One', cursive; font-weight: 700; font-size: 1.2em; background: rgba(255,182,193,.3); color: #ff1493; text-transform: uppercase; letter-spacing: 2px; box-shadow: 0 5px 15px rgba(255,182,193,.4); transition: all .3s ease; }
    .btn2:hover { transform: translateY(-3px) scale(1.03); box-shadow: 0 8px 25px rgba(255,182,193,.6); border-color: #ff1493; background: rgba(255,182,193,.5); }
    .err { color: #ff4757; margin-top: 12px; font-family: 'Comic Neue', cursive; font-weight: 700; font-size: 1.1em; text-shadow: 1px 1px 2px rgba(0,0,0,.2); animation: wiggle .5s ease; }
</style>

@* אם משתמש עדיין לא מחובר מציגים loading *@
@if (Session.CurrentUserId is null)
{
    <div class="wrap"><div class="card">Loading...</div></div>
}
else
{
    <div class="wrap">
        <div class="card">
            <div class="title">Quick Play</div>
            <div class="sub">Join a room by code.</div>

            @* קלט קוד חדר ידני *@
            <input class="in" @bind="RoomCode" placeholder="Room code (e.g., ABC123)" />
            @* קלט Nickname שמוצג בלובי לשחקנים אחרים *@
            <input class="in" @bind="Nickname" placeholder="Nickname (display name)" />

            @* כפתור Join Room: מצטרף לפי הקוד שהוזן *@
            <button class="btn" @onclick="JoinAsync">Join Room</button>
            @* חזרה לתפריט הראשי *@
            <button class="btn2" @onclick="@(() => Nav.NavigateTo("/menu", true))">Back to Menu</button>

            @if (!string.IsNullOrWhiteSpace(Status))
            {
                <div class="err">@Status</div>
            }

            <div style="margin-top:20px;">
                <div class="title">Public Rooms</div>
                <div class="sub">Everyone can see and join these rooms.</div>

                @if (PublicRooms.Count == 0)
                {
                    <div class="err">No public rooms available right now.</div>
                }
                else
                {
                    @* עבור כל חדר ציבורי מציגים שם/קוד וכפתור Join ישיר *@
                    @foreach (var room in PublicRooms)
                    {
                        <div style="display:flex; justify-content:space-between; align-items:center; margin:10px 0; padding:12px 16px; border-radius:15px; background: rgba(255,255,255,0.8); border:2px solid rgba(255,182,193,0.4);">
                            <div>
                                <div style="font-weight:800; font-family:'Comic Neue', cursive;">@room.RoomName</div>
                                <div style="opacity:0.8;">Code: @room.RoomCode</div>
                            </div>
                            @* Join ציבורי: מפעיל JoinPublicAsync עם הקוד של אותו חדר *@
                            <button class="btn2" style="width:auto; margin:0;" @onclick="@(() => JoinPublicAsync(room.RoomCode))">Join</button>
                        </div>
                    }
                }
            </div>

        </div>
    </div>
}

@code {
    // הסבר עמוד: הצטרפות לחדר לפי קוד + הצגת חדרים ציבוריים בלייב.
    // קוד החדר שמוקלד ידנית או נלקח מרשימת החדרים.
    private string RoomCode = ""; // קוד חדר שהמשתמש מקליד
    // שם תצוגה שנשלח יחד עם ההצטרפות לחדר.
    private string Nickname = ""; // כינוי להצגה בלובי
    // הודעת שגיאה או מצב שמוצגת מתחת לטופס.
    private string Status = ""; // הודעת שגיאה/סטטוס
    // הרשימה שנמשכת מהמסד ומוצגת במסך החדרים הציבוריים.
    private List<Room> PublicRooms = new(); // רשימת חדרים ציבוריים זמינים

    // שכבת הגישה לנתוני חדרים.
    private readonly RoomDB roomDB = new(); // גישת מסד לחדרים
    // חיבור SignalR שמאזין לשינויים בזמן אמת.
    private HubConnection? hub; // חיבור SignalR לעדכוני חדרים
    // ריענון תקופתי כגיבוי למקרה שה-SignalR מתנתק.
    private System.Threading.Timer? refreshTimer; // רענון fallback תקופתי

    // אתחול עמוד: טעינת חדרים ציבוריים + האזנה לעדכונים בזמן אמת.
    // טוענים רשימה ראשונית ואז מחברים את ה-hub.
    protected override async Task OnInitializedAsync()
    {
        await LoadPublicRoomsAsync();

        hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/game"))
            .WithAutomaticReconnect()
            .Build();

        hub.On("PublicRoomChanged", async () =>
        {
            await LoadPublicRoomsAsync();
            await InvokeAsync(StateHasChanged);
        });

        await hub.StartAsync();

        refreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadPublicRoomsAsync();
                StateHasChanged();
            });
        }, null, 5000, 5000);
    }

    // לחיצה על Join Room: מצטרפים לפי הקוד שהוזן ידנית.
    // מנסה להצטרף לחדר לפי קוד ידני שהמשתמש הקליד.
    private async Task JoinAsync()
    {
        Status = "";
        var code = (RoomCode ?? "").Trim().ToUpperInvariant();
        var nick = (Nickname ?? "").Trim();

        if (code.Length == 0)
        {
            Status = "Room code is required.";
            return;
        }

        var room = await roomDB.GetRoomByCodeAsync(code);
        if (room is null || !room.IsActive)
        {
            Status = "Room not found or inactive.";
            return;
        }

        var joined = await roomDB.JoinRoomAsync(room.RoomID, Session.CurrentUserId.Value, nick);
        if (joined is null)
        {
            Status = "Failed to join room.";
            return;
        }

        Nav.NavigateTo($"/lobby/{code}", true);
    }

    // לחיצה על Join בחדר ציבורי: ממלא קוד ואז משתמש באותה לוגיקת JoinAsync.
    // קיצור דרך להצטרפות לחדר שנבחר מהרשימה הציבורית.
    private async Task JoinPublicAsync(string roomCode)
    {
        RoomCode = roomCode;
        await JoinAsync();
    }

    // טעינת רשימת חדרים ציבוריים מהמסד.
    // מושכת מחדש את רשימת החדרים הציבוריים מהמסד.
    private async Task LoadPublicRoomsAsync()
    {
        PublicRooms = await roomDB.GetPublicRoomsAsync();
    }

    // ניקוי משאבים ביציאה מהעמוד.
    // סוגרים את הרענון ואת ה-hub כשעוזבים את הדף.
    public async ValueTask DisposeAsync()
    {
        refreshTimer?.Dispose();
        if (hub is not null)
        {
            try { await hub.StopAsync(); } catch { }
            await hub.DisposeAsync();
        }
    }
}
