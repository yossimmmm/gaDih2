@page "/reset-password"

@* KEYWORDS: reset password, token, reset link *@
@* הדף הזה מקבל token מה-URL ומשתמש בו כדי להחליף סיסמה. *@

@* מכולת מרכזית של מסך איפוס סיסמה *@
<div style="max-width:420px;margin:80px auto;padding:24px;border:1px solid #ddd;border-radius:12px">
    @* כותרת הטופס *@
    <h3>Reset Password</h3>
    @* שדה סיסמה חדשה *@
    <input id="reset-password-input" style="width:100%;padding:10px;margin:8px 0" type="password" placeholder="New password" />
    @* שדה אימות סיסמה חדשה *@
    <input id="reset-confirm-input" style="width:100%;padding:10px;margin:8px 0" type="password" placeholder="Confirm new password" />
    @* כפתור שליחת האיפוס *@
    <button id="reset-submit-btn" style="width:100%;padding:10px" type="button">Set New Password</button>
    @* אזור הודעת סטטוס (שגיאה/הצלחה) *@
    <div id="reset-status" style="margin-top:10px"></div>
    @* קישור חזרה ללוגין *@
    <div style="margin-top:12px"><a href="/login">Back to login</a></div>
</div>

@* כל הוולידציה האמיתית נעשית בצד הלקוח לפני הקריאה לשרת. *@
<script>
  (function () {
    // שליפת אלמנטים מה-DOM לפי מזהים
    const passwordInput = document.getElementById("reset-password-input");
    const confirmInput = document.getElementById("reset-confirm-input");
    const submitBtn = document.getElementById("reset-submit-btn");
    const statusEl = document.getElementById("reset-status");

    // אם חסר אלמנט קריטי - עוצרים כדי למנוע שגיאות JS
    if (!passwordInput || !confirmInput || !submitBtn || !statusEl) return;

    // שליפת token מה-query string של הקישור שנשלח במייל
    const token = new URLSearchParams(window.location.search).get("token") || "";
    // דגל שמציין האם בקשה כרגע רצה
    let isLoading = false;
    // דגל שמציין אם הפעולה הושלמה בהצלחה
    let isDone = false;

    // פונקציית עזר: הצגת טקסט סטטוס + צבע לפי הצלחה/שגיאה
    function setStatus(text, ok) {
      statusEl.textContent = text || "";
      statusEl.style.color = ok ? "#1b8f3a" : "#c62828";
    }

    // פונקציית עזר: נעילת/שחרור שדות וכפתור בזמן תהליך
    function setLoading(next) {
      isLoading = next;
      passwordInput.disabled = isLoading || isDone;
      confirmInput.disabled = isLoading || isDone;
      submitBtn.disabled = isLoading || isDone;
    }

    // מאזין ללחיצה על כפתור איפוס סיסמה
    submitBtn.addEventListener("click", async function () {
      // אם כבר בתהליך/סיימנו - לא מבצעים שוב
      if (isLoading || isDone) return;
      // ניקוי הודעה קודמת לפני ניסיון חדש
      setStatus("", false);

      // קריאת ערכי הקלט והסרת רווחים
      const password = (passwordInput.value || "").trim();
      const confirmPassword = (confirmInput.value || "").trim();

      // חובה token תקין מהקישור באימייל
      if (!token) {
        setStatus("Missing reset token. Open the link from your email.", false);
        return;
      }

      // חובה למלא את שני השדות
      if (!password || !confirmPassword) {
        setStatus("Please fill both password fields.", false);
        return;
      }

      // הסיסמה והאימות חייבים להיות זהים
      if (password !== confirmPassword) {
        setStatus("Passwords do not match.", false);
        return;
      }

      // מעבר למצב טעינה לפני יציאה לשרת
      setLoading(true);
      try {
        // קריאה ל-auth.js ששולח request לשרת לאיפוס סיסמה
        const res = await window.auth.resetPassword(token, password);
        // במסלול הצלחה
        if (res && res.ok) {
          // הודעת הצלחה למשתמש
          setStatus("Password updated. Redirecting to login...", true);
          // סימון שהפעולה הסתיימה
          isDone = true;
          // מעבר אוטומטי ללוגין אחרי זמן קצר
          setTimeout(function () { window.location.href = "/login"; }, 1200);
          return;
        }
        // במסלול שגיאה מהשרת
        setStatus((res && res.message) || "Invalid or expired reset link.", false);
      } catch (e) {
        // טיפול בשגיאת רשת/קוד לא צפויה
        setStatus("Could not reset password right now.", false);
      } finally {
        // שחרור נעילה תמיד, גם בהצלחה וגם בשגיאה
        setLoading(false);
      }
    });
  })();
</script>
