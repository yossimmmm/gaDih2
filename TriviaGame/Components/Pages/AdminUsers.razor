@page "/admin-users"
@inherits AuthPageBase
@using Models
@using DBL
@rendermode InteractiveServer

<div class="admin-users-page">
    <!-- מעטפת המסך: מרכזת את תוכן הניהול על רקע מלא. -->
    <div class="admin-users-card">
        <!-- כותרת עליונה וכפתור טעינה מחדש. -->
        <div class="admin-users-header">
            <h1>Admin Users</h1>
            <button class="reload-btn" @onclick="LoadUsersAsync" disabled="@Busy">Reload</button>
        </div>

        <!-- אם המשתמש לא אדמין, לא מציגים את הטבלה בכלל. -->
        @if (!IsAllowed)
        {
            <p class="status error">Only admins can open this page.</p>
        }
        @* בזמן טעינה ראשונית ורשימה ריקה, מציגים הודעת המתנה. *@
        else if (Busy && Users.Count == 0)
        {
            <p class="status">Loading users...</p>
        }
        @* אחרת מציגים את טבלת העריכה של המשתמשים. *@
        else
        {
            <div class="table-wrap">
                <!-- טבלה לעריכה ישירה של פרטי משתמשים. -->
                <table>
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Email</th>
                            <th>Username</th>
                            <th>Full Name</th>
                            <th>Role</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Users)
                        {
                            <tr>
                                <td>@row.UserID</td>
                                <td><input @bind="row.Email" /></td>
                                <td><input @bind="row.Username" /></td>
                                <td><input @bind="row.FullName" /></td>
                                <td>
                                    <select @bind="row.Role">
                                        <option value="@UserRole.User">User</option>
                                        <option value="@UserRole.Admin">Admin</option>
                                    </select>
                                </td>
                                <td>
                                    <div class="actions">
                                        <button class="save-btn" @onclick="() => SaveUserAsync(row)" disabled="@Busy">Save</button>
                                        <button class="delete-btn" @onclick="() => DeleteUserAsync(row)" disabled="@Busy || row.UserID == Session.CurrentUserId">Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- הודעת הצלחה או שגיאה אחרי פעולה של אדמין. -->
        @if (!string.IsNullOrWhiteSpace(Status))
        {
            <p class="status @(IsError ? "error" : "ok")">@Status</p>
        }
    </div>
</div>

@code {
    // שכבת הגישה לנתוני משתמשים דרך ה-DB.
    private readonly UserDB userDb = new();
    // הרשימה שנערכה על המסך לצורך עריכה מהירה.
    private List<AdminUserRow> Users = new();
    // הודעת מצב שמוצגת למנהל אחרי פעולה.
    private string Status = "";
    // מציין אם הפעולה האחרונה נכשלה.
    private bool IsError;
    // מונע לחיצות כפולות בזמן טעינה או שמירה.
    private bool Busy;
    // רק אדמין יכול לעבוד עם המסך הזה.
    private bool IsAllowed => Session.CurrentRole == UserRole.Admin;

    // ברגע שהמשתמש עבר אימות, טוענים את רשימת המשתמשים.
    protected override async Task OnAuthedAsync()
    {
        await LoadUsersAsync();
    }

    // טוען את כל המשתמשים מהמסד וממפה אותם למבנה שמתאים לעריכה בטבלה.
    private async Task LoadUsersAsync()
    {
        if (!IsAllowed)
            return;

        Busy = true;
        Status = "";
        IsError = false;
        try
        {
            Users = (await userDb.GetAllUsersAsync()).Select(u => new AdminUserRow
            {
                UserID = u.UserID,
                Email = u.Email,
                Username = u.Username,
                FullName = u.FullName,
                Role = u.Role
            }).ToList();
        }
        catch
        {
            IsError = true;
            Status = "Failed to load users.";
        }
        finally
        {
            Busy = false;
        }
    }

    // שומר שורה אחת אחרי שהאדמין ערך אותה בטבלה.
    private async Task SaveUserAsync(AdminUserRow row)
    {
        if (!IsAllowed)
            return;

        // בודקים שהאימייל עדיין חוקי לפני ששולחים עדכון למסד.
        if (string.IsNullOrWhiteSpace(row.Email) || !ValidationHelper.IsValidEmail(row.Email))
        {
            IsError = true;
            Status = $"Invalid email for user {row.UserID}.";
            return;
        }

        Busy = true;
        Status = "";
        IsError = false;
        try
        {
            var ok = await userDb.UpdateUserByAdminAsync(row.UserID, row.Username, row.FullName, row.Email, row.Role);
            IsError = !ok;
            Status = ok ? $"User {row.UserID} updated." : $"Failed to update user {row.UserID}.";
        }
        catch
        {
            IsError = true;
            Status = $"Update failed for user {row.UserID}.";
        }
        finally
        {
            Busy = false;
        }
    }

    // מוחק משתמש מהמערכת, אבל לא מאפשר למחוק את עצמך.
    private async Task DeleteUserAsync(AdminUserRow row)
    {
        if (!IsAllowed)
            return;

        // הגנה בסיסית: אדמין לא מוחק את החשבון של עצמו.
        if (row.UserID == Session.CurrentUserId)
        {
            IsError = true;
            Status = "You cannot delete your own admin account.";
            return;
        }

        Busy = true;
        Status = "";
        IsError = false;
        try
        {
            var ok = await userDb.DeleteUserAsync(row.UserID);
            if (!ok)
            {
                IsError = true;
                Status = $"Failed to delete user {row.UserID}.";
                return;
            }

            Users.Remove(row);
            Status = $"User {row.UserID} deleted.";
        }
        catch
        {
            IsError = true;
            Status = $"Delete failed for user {row.UserID}.";
        }
        finally
        {
            Busy = false;
        }
    }

    // DTO פנימי שמחזיק את הנתונים של שורת הטבלה.
    private sealed class AdminUserRow
    {
        // מזהה המשתמש במסד.
        public int UserID { get; set; }
        // כתובת המייל לעריכה.
        public string Email { get; set; } = "";
        // שם המשתמש.
        public string Username { get; set; } = "";
        // השם המלא.
        public string FullName { get; set; } = "";
        // התפקיד שניתן לעריכה ישירה מהטבלה.
        public UserRole Role { get; set; } = UserRole.User;
    }
}

<style>
    .admin-users-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #e7bfd6 0%, #dcaab7 100%);
        padding: 24px;
        display: flex;
        justify-content: center;
        align-items: flex-start;
    }

    .admin-users-card {
        width: min(1200px, 100%);
        background: #f3f2f6;
        border: 2px solid #ea77b8;
        border-radius: 22px;
        padding: 24px;
        box-shadow: 0 12px 36px rgba(34, 26, 34, 0.08);
    }

    .admin-users-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .admin-users-header h1 {
        margin: 0;
        color: #2b2f3a;
        font-size: 44px;
        line-height: 1.1;
    }

    .reload-btn, .save-btn, .delete-btn {
        border-radius: 10px;
        border: 2px solid #2b2f3a;
        background: #ffffff;
        color: #2b2f3a;
        font-size: 18px;
        font-weight: 700;
        padding: 10px 14px;
        min-height: 44px;
        transition: 140ms ease;
    }

    .reload-btn:hover, .save-btn:hover {
        background: #f0e8f8;
    }

    .delete-btn {
        border-color: #8b1f3e;
        color: #8b1f3e;
    }

    .delete-btn:hover {
        background: #ffe5ef;
    }

    .reload-btn:disabled, .save-btn:disabled, .delete-btn:disabled {
        opacity: .45;
        cursor: not-allowed;
    }

    .table-wrap {
        overflow-x: auto;
        border: 2px solid #dbc2d4;
        border-radius: 14px;
        background: #fff;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        min-width: 920px;
    }

    th, td {
        padding: 10px;
        border-bottom: 1px solid #eed6e7;
        text-align: left;
        vertical-align: middle;
    }

    th {
        background: #f8eef6;
        color: #3e3f49;
        font-size: 16px;
    }

    td {
        color: #2e2f38;
        font-size: 15px;
    }

    input, select {
        width: 100%;
        min-height: 40px;
        border: 1px solid #b8b5c1;
        border-radius: 8px;
        font-size: 15px;
        color: #2e2f38;
        background: #fff;
        padding: 8px 10px;
    }

    .actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .status {
        margin: 14px 0 0;
        font-size: 16px;
        color: #36404c;
        font-weight: 600;
    }

    .status.ok {
        color: #0e6840;
    }

    .status.error {
        color: #9a2243;
    }

    @@media (max-width: 720px) {
        .admin-users-page {
            padding: 12px;
        }

        .admin-users-card {
            padding: 14px;
        }

        .admin-users-header h1 {
            font-size: 30px;
        }
    }
</style>
