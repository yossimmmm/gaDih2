@page "/results/{RoomCode}"
@inherits AuthPageBase
@using Models
@using DBL
@using System.Linq
@rendermode InteractiveServer

@* #results #scoreboard #winner #ranking #play #game-over #statistics *@
@* מסך התוצאות: כאן רואים את הניקוד הסופי, המנצח, והדירוג של כל השחקנים בחדר. *@

<style>
    .wrap { min-height: 100vh; display: flex; justify-content: center; align-items: center; background: linear-gradient(135deg,#ff9a9e 0%,#fecfef 25%,#fecfef 50%,#fad0c4 75%,#ffd1ff 100%); background-attachment: fixed; color: #333; font-family: 'Comic Neue', cursive; position: relative; overflow: hidden; padding: 20px; }
    .wrap::before { content: "🏆"; position: absolute; font-size: 5em; animation: float 3s ease-in-out infinite; top: 5%; left: 5%; opacity: 0.6; }
    .wrap::after { content: "🎉"; position: absolute; font-size: 4em; animation: float 4s ease-in-out infinite reverse; top: 10%; right: 8%; opacity: 0.5; }
    .card { width: 600px; max-width: 95%; background: linear-gradient(135deg, rgba(255,255,255,.95) 0%, rgba(255,240,245,.95) 100%); border: 5px solid #ffd700; border-radius: 35px; padding: 40px; box-shadow: 0 15px 40px rgba(255,215,0,.5), 0 0 60px rgba(255,182,193,.4); backdrop-filter: blur(10px); position: relative; z-index: 1; animation: pulse-glow 3s ease-in-out infinite; transform-style: preserve-3d; }
    .card::before { content: "👑"; position: absolute; top: -25px; left: -25px; font-size: 4em; animation: bounce 2s infinite; z-index: -1; }
    .card::after { content: "⭐"; position: absolute; bottom: -20px; right: -20px; font-size: 3em; animation: bounce 2.5s infinite; z-index: -1; }
    .title { font-size: 2.5rem; font-family: 'Fredoka One', cursive; color: #ffd700; text-shadow: 3px 3px 0 #ffed4e, 6px 6px 10px rgba(255,215,0,.5), 0 0 20px rgba(255,182,193,.5); margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; gap: 15px; flex-wrap: wrap; animation: float 2s ease-in-out infinite; text-align: center; width: 100%; }
    .btn2 { padding: 18px 30px; border-radius: 25px; border: 4px solid #ffb6c1; cursor: pointer; font-family: 'Fredoka One', cursive; font-weight: 800; font-size: 1.2em; background: rgba(255,182,193,.3); color: #ff1493; text-transform: uppercase; letter-spacing: 2px; box-shadow: 0 5px 15px rgba(255,182,193,.4); transition: all .3s ease; margin-top: 20px; width: 100%; }
    .row { display: flex; justify-content: space-between; align-items: center; padding: 20px; margin: 15px 0; border-bottom: 3px dashed rgba(255,182,193,.4); background: linear-gradient(135deg, rgba(255,255,255,.8), rgba(255,240,245,.8)); border-radius: 20px; transition: all .3s ease; font-family: 'Comic Neue', cursive; font-weight: 700; font-size: 1.2em; color: #333; box-shadow: 0 3px 10px rgba(255,182,193,.2); }
    .badge { opacity: .9; font-family: 'Comic Neue', cursive; font-weight: 700; font-size: 1.1em; color: #ff1493; padding: 8px 15px; background: rgba(255,182,193,.4); border-radius: 15px; border: 2px solid #ff69b4; box-shadow: 0 2px 8px rgba(255,182,193,.3); }
</style>

@if (Session.CurrentUserId is null)
{
    <div class="wrap"><div class="card">Loading...</div></div>
}
else
{
    <div class="wrap">
        <div class="card">
            <div class="title">
                <span>🏆 Results</span>
                <span class="badge">Room: @RoomCode</span>
            </div>

            @if (Rows.Count == 0)
            {
                <div class="badge">No scores yet.</div>
            }
            else
            {
                @* הודעת מנצח/ים לפי לוגיקת UpdateWinnerText *@
                @if (!string.IsNullOrWhiteSpace(WinnerText))
                {
                    <div class="badge">@WinnerText</div>
                }

                @* טבלת ניקוד: כל שחקן עם correct/answered *@
                @foreach (var r in Rows)
                {
                    <div class="row">
                        <div>@r.Nickname</div>
                        <div class="badge">@r.CorrectCount / @r.AnsweredCount</div>
                    </div>
                }
            }

            <div style="margin-top:14px">
                @* חזרה לתפריט הראשי *@
                <button class="btn2" @onclick="@(() => Nav.NavigateTo("/menu", true))">Back to Menu</button>
                @* מעבר לסטטיסטיקות האישיות *@
                <button class="btn2" @onclick="@(() => Nav.NavigateTo("/stats", true))">View My Stats</button>
            </div>

        </div>
    </div>
}

@code {
    // הסבר עמוד: טעינה והצגה של תוצאות משחק לפי קוד חדר.
    [Parameter] public string RoomCode { get; set; } = ""; // קוד חדר מה-URL

    private int RoomId = 0; // מזהה חדר פנימי במסד
    private List<ScoreRow> Rows = new(); // שורות תוצאות לשחקנים
    private string WinnerText = ""; // טקסט מנצח/ים להצגה
    private int TotalQuestions = 0; // מספר שאלות כולל בחדר

    private readonly RoomDB roomDB = new(); // DB חדרים
    private readonly GameDB gameDB = new(); // DB תוצאות/ניקוד
    private bool Loaded = false; // מניעת טעינה כפולה

    // טעינת נתוני תוצאות אחרי אימות משתמש.
    // #results: loads the scoreboard and decides which players won.
    protected override async Task OnAuthedAsync()
    {
        if (Loaded)
            return;
        Loaded = true;

        var room = await roomDB.GetRoomByCodeAsync(RoomCode.Trim().ToUpperInvariant());
        if (room is null)
        {
            Nav.NavigateTo("/menu", true);
            return;
        }

        RoomId = room.RoomID;
        Rows = await gameDB.GetScoreboardAsync(RoomId);
        TotalQuestions = await gameDB.GetRoomQuestionCountAsync(RoomId);
        UpdateWinnerText();
        await gameDB.SaveRoomResultsAsync(RoomId);
    }

    // קובע איזה טקסט מנצח יוצג לפי הנתונים.
    // #results #winner: turns the raw scoreboard into the visible winner message.
    private void UpdateWinnerText()
    {
        if (Rows.Count == 0)
        {
            WinnerText = "";
            return;
        }

        if (Rows.Count == 1)
        {
            var r = Rows[0];
            if (TotalQuestions > 0 && r.AnsweredCount == TotalQuestions && r.CorrectCount == TotalQuestions)
                WinnerText = $"Winner: {r.Nickname}";
            else
                WinnerText = "You did not win. You must answer every question correctly.";
            return;
        }

        var maxCorrect = Rows.Max(r => r.CorrectCount);
        var winners = Rows.Where(r => r.CorrectCount == maxCorrect).Select(r => r.Nickname).ToList();
        WinnerText = winners.Count == 1
            ? $"Winner: {winners[0]}"
            : $"Winners: {string.Join(", ", winners)}";
    }
}
