@page "/top-players"
@inherits AuthPageBase
@using Models
@using DBL
@rendermode InteractiveServer

@* #top-players #leaderboard #ranking #statistics #wins #correct-answers *@
@* מסך טבלת המובילים: כאן רואים את הדירוג הכללי של כל השחקנים באתר. *@

<style>
    .wrap { min-height: 100vh; display: flex; justify-content: center; align-items: center; background: linear-gradient(135deg,#ff9a9e 0%,#fecfef 25%,#fecfef 50%,#fad0c4 75%,#ffd1ff 100%); background-attachment: fixed; color: #333; font-family: 'Comic Neue', cursive; position: relative; overflow: hidden; padding: 20px; }
    .card { width: 620px; max-width: 95%; background: linear-gradient(135deg, rgba(255,255,255,.95) 0%, rgba(255,240,245,.95) 100%); border: 5px solid #ff69b4; border-radius: 35px; padding: 40px; box-shadow: 0 15px 40px rgba(255,20,147,.4), 0 0 60px rgba(255,182,193,.3); backdrop-filter: blur(10px); position: relative; z-index: 1; animation: pulse-glow 3s ease-in-out infinite; transform-style: preserve-3d; }
    .title { font-size: 2.3rem; font-family: 'Fredoka One', cursive; color: #ff1493; text-shadow: 3px 3px 0 #ff69b4, 6px 6px 10px rgba(255,20,147,.4); margin-bottom: 15px; letter-spacing: 2px; text-align: center; }
    .row { display: flex; justify-content: space-between; align-items: center; padding: 16px; margin: 10px 0; border-radius: 18px; background: rgba(255,255,255,.8); border: 2px solid rgba(255,182,193,.4); font-weight: 700; gap: 8px; flex-wrap: wrap; }
    .badge { padding: 6px 12px; border-radius: 12px; background: rgba(255,182,193,.4); color: #ff1493; border: 2px solid #ff69b4; font-size: .95em; }
    .btn2 { width: 100%; padding: 14px; border-radius: 25px; border: 4px solid #ffb6c1; cursor: pointer; font-family: 'Fredoka One', cursive; font-weight: 700; font-size: 1.1em; background: rgba(255,182,193,.3); color: #ff1493; text-transform: uppercase; letter-spacing: 2px; box-shadow: 0 5px 15px rgba(255,182,193,.4); transition: all .3s ease; margin-top: 20px; }
</style>

@* אם אין משתמש מאומת עדיין מציגים טעינה *@
@if (Session.CurrentUserId is null)
{
    <div class="wrap"><div class="card">Loading...</div></div>
}
else
{
    <div class="wrap">
        <div class="card">
            @* כותרת מסך טבלת מובילים *@
            <div class="title">Top Players</div>

            @if (Rows.Count == 0)
            {
                <div class="row">No data yet.</div>
            }
            else
            {
                @* רינדור שחקנים מובילים מהשרת *@
                @foreach (var row in Rows)
                {
                    <div class="row">
                        <div>@row.Username</div>
                        <div class="badge">@row.CorrectCount / @row.AnsweredCount</div>
                        <div class="badge">Wins: @row.Wins</div>
                        <div class="badge">Games: @row.GamesPlayed</div>
                        <div class="badge">Acc: @GetAccuracy(row)%</div>
                    </div>
                }
            }

            @* חזרה לתפריט הראשי *@
            <button class="btn2" @onclick="@(() => Nav.NavigateTo("/menu", true))">Back to Menu</button>

        </div>
    </div>
}

@code {
    // הסבר עמוד: טעינה והצגה של שחקנים מובילים לפי נתוני תוצאות מצטברים.
    private List<TopPlayerRow> Rows = new(); // רשימת השחקנים המובילים
    private readonly GameDB gameDB = new(); // גישת מסד לנתוני תוצאות
    private bool Loaded = false; // מניעת טעינה כפולה

    // טעינת טבלת מובילים לאחר אימות משתמש.
    // #leaderboard: loads the global top-player table.
    protected override async Task OnAuthedAsync()
    {
        if (Loaded)
            return;
        Loaded = true;
        Rows = await gameDB.GetTopPlayersAsync(10);
    }

    // מחשב אחוז דיוק להצגה לפי correct/answered.
    private static string GetAccuracy(TopPlayerRow row)
    {
        if (row.AnsweredCount <= 0)
            return "0";
        var acc = (double)row.CorrectCount / row.AnsweredCount * 100.0;
        return acc.ToString("0");
    }
}
