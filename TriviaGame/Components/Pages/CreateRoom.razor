@page "/create-room"
@inherits AuthPageBase
@using Models
@using DBL
@using Microsoft.AspNetCore.SignalR.Client
@rendermode InteractiveServer

@* #create-room #solo-game #groups #room-code #public-room #private-room #play *@
@* מסך יצירת החדר: כאן בוחרים איך לפתוח משחק, לבד או כקבוצה, ומייצרים קוד חדר. *@

<style>
    .wrap {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 25%, #fecfef 50%, #fad0c4 75%, #ffd1ff 100%);
        background-attachment: fixed;
        color: #333;
        font-family: 'Comic Neue', cursive;
        position: relative;
        overflow: hidden;
        padding: 20px;
    }
    
    .wrap::before {
        content: "??";
        position: absolute;
        font-size: 4em;
        animation: float 3s ease-in-out infinite;
        top: 5%;
        left: 5%;
        opacity: 0.6;
    }

    .card {
        width: 500px;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 240, 245, 0.95) 100%);
        border: 5px solid #ff69b4;
        border-radius: 35px;
        padding: 40px;
        box-shadow: 0 15px 40px rgba(255, 20, 147, 0.4), 0 0 60px rgba(255, 182, 193, 0.3);
        backdrop-filter: blur(10px);
        position: relative;
        z-index: 1;
        animation: pulse-glow 3s ease-in-out infinite;
        transform-style: preserve-3d;
    }
    
    .card::before {
        content: "??";
        position: absolute;
        top: -25px;
        right: -25px;
        font-size: 4em;
        animation: bounce 2s infinite;
        z-index: -1;
    }

    .title {
        font-size: 2.3rem;
        font-family: 'Fredoka One', cursive;
        color: #ff1493;
        text-shadow: 3px 3px 0px #ff69b4, 6px 6px 10px rgba(255, 20, 147, 0.4);
        margin-bottom: 15px;
        letter-spacing: 2px;
        animation: float 2s ease-in-out infinite;
        text-align: center;
    }

    .sub {
        margin-bottom: 25px;
        opacity: 0.8;
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.1em;
        color: #666;
        text-align: center;
    }

    .in {
        width: 100%;
        padding: 15px 20px;
        margin: 12px 0;
        border-radius: 20px;
        border: 3px solid #ffb6c1;
        background: rgba(255, 255, 255, 0.9);
        color: #333;
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.1em;
        transition: all 0.3s ease;
        box-shadow: inset 0 2px 5px rgba(0, 0, 0, 0.1);
    }
    
    .in:focus {
        outline: none;
        border-color: #ff1493;
        box-shadow: 0 0 20px rgba(255, 20, 147, 0.5), inset 0 2px 5px rgba(0, 0, 0, 0.1);
        transform: scale(1.02);
        background: #fff;
    }
    
    .in::placeholder {
        color: rgba(255, 105, 180, 0.6);
        font-weight: 700;
    }

    .btn {
        width: 100%;
        padding: 18px;
        margin: 10px 0;
        border-radius: 25px;
        border: 4px solid #ff1493;
        cursor: pointer;
        font-family: 'Fredoka One', cursive;
        font-weight: 700;
        font-size: 1.2em;
        background: linear-gradient(135deg, #ff6b9d 0%, #ff8fab 50%, #ffa8c5 100%);
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 2px;
        box-shadow: 0 8px 20px rgba(255, 20, 147, 0.4);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }
    
    .btn::before {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.3);
        transform: translate(-50%, -50%);
        transition: width 0.6s, height 0.6s;
    }
    
    .btn:hover::before {
        width: 400px;
        height: 400px;
    }
    
    .btn:hover {
        transform: translateY(-5px) scale(1.05);
        box-shadow: 0 12px 30px rgba(255, 20, 147, 0.6);
        animation: bounce 0.6s ease;
    }

    .btn2 {
        width: 100%;
        padding: 18px;
        margin: 10px 0;
        border-radius: 25px;
        border: 4px solid #ffb6c1;
        cursor: pointer;
        font-family: 'Fredoka One', cursive;
        font-weight: 700;
        font-size: 1.2em;
        background: rgba(255, 182, 193, 0.3);
        color: #ff1493;
        text-transform: uppercase;
        letter-spacing: 2px;
        box-shadow: 0 5px 15px rgba(255, 182, 193, 0.4);
        transition: all 0.3s ease;
    }
    
    .btn2:hover {
        transform: translateY(-3px) scale(1.03);
        box-shadow: 0 8px 25px rgba(255, 182, 193, 0.6);
        border-color: #ff1493;
        background: rgba(255, 182, 193, 0.5);
    }

    .err {
        color: #ff4757;
        margin-top: 12px;
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.1em;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
        animation: wiggle 0.5s ease;
    }

    .ok {
        color: #2ed573;
        margin-top: 12px;
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.1em;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
    }

    .code {
        margin-top: 15px;
        font-size: 2rem;
        letter-spacing: 5px;
        font-weight: 800;
        font-family: 'Fredoka One', cursive;
        color: #ff1493;
        text-shadow: 3px 3px 0px #ff69b4, 0 0 20px rgba(255, 20, 147, 0.6);
        text-align: center;
        padding: 15px;
        background: linear-gradient(135deg, rgba(255, 182, 193, 0.3), rgba(255, 240, 245, 0.5));
        border-radius: 20px;
        border: 3px dashed #ff69b4;
        animation: pulse-glow 2s ease-in-out infinite;
    }
</style>

@if (Session.CurrentUserId is null)
{
    @* אם אין משתמש מאומת כרגע, מציגים מסך טעינה קצר *@
    <div class="wrap"><div class="card">Loading...</div></div>
}
else
{
    <div class="wrap">
        <div class="card">
            <div class="title">Create Room</div>
            @* מציג את מזהה המשתמש המחובר שיהיה ה-Host של החדר *@
            <div class="sub">Host user ID: @Session.CurrentUserId</div>

            @* שדה שם חדר: נקלט ל-RoomName דרך @bind לשימוש ביצירה במסד *@
            <input class="in" @bind="RoomName" placeholder="Room name (e.g., Friday Night Trivia)" />
            @* צ'קבוקס Public: אם מסומן - החדר ציבורי ומופיע לכולם ברשימת חדרים *@
            <label style="display:flex; align-items:center; gap:10px; margin:10px 0; font-family: 'Comic Neue', cursive; font-weight:700; color:#ff1493;">
                <input type="checkbox" @bind="IsPublic" />
                Public room (visible to everyone)
            </label>
            @* בחירת נושא: אם לא נבחר ערך -> All topics, אחרת שומרים SelectedTopicId *@
            <select class="in" @bind="SelectedTopicId">
                <option value="">All topics</option>
                @foreach (var t in Topics)
                {
                    <option value="@t.QuestionTypeID">@t.TypeName</option>
                }
            </select>

            @* כפתור Create: מפעיל CreateRoomAsync שיוצר חדר, מוסיף Host ומנווט ללובי *@
            <button class="btn" @onclick="CreateRoomAsync">Create</button>
            @* כפתור Back: חוזר לתפריט הראשי עם רענון מלא *@
            <button class="btn2" @onclick="@(() => Nav.NavigateTo("/menu", true))">Back to Menu</button>

            @* אם קיימת שגיאה - מציגים אותה למשתמש *@
            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <div class="err">@Error</div>
            }

        </div>
    </div>
}

@code {
    // הסבר עמוד: לוגיקת CreateRoom וניהול מצב המסך.
    // שם החדר שהמשתמש מקליד בטופס.
    private string RoomName = "";
    // הודעת שגיאה להצגה ב-UI במקרה ולידציה/DB נכשלת.
    private string Error = "";
    // מופע חדר שנוצר (נשמר למעקב פנימי, לא מוצג כרגע).
    private Room? CreatedRoom;
    // האם החדר ציבורי או פרטי.
    private bool IsPublic = false;
    // רשימת נושאים ל-select (נטענת מהמסד בטעינה ראשונית).
    private List<QuestionType> Topics = new();
    // מזהה נושא נבחר; null = כל הנושאים.
    private int? SelectedTopicId = null;

    // שכבת DB לחדרים.
    private readonly RoomDB roomDB = new();
    // שכבת DB לסוגי שאלות.
    private readonly QuestionTypeDB questionTypeDB = new();
    // חיבור SignalR לעדכון בזמן אמת על שינוי חדרים ציבוריים.
    private HubConnection? hub;

    // אתחול עמוד: טוען נושאים ופותח חיבור Hub לעדכונים חיים.
    // #create-room: loads topics and opens the SignalR connection used by the room creator.
    protected override async Task OnInitializedAsync()
    {
        // קריאת כל הנושאים מהמסד כדי לאפשר בחירה ב-select.
        Topics = await questionTypeDB.GetAllAsync();
        // בניית חיבור SignalR ל-hub של המשחק.
        hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/game"))
            .WithAutomaticReconnect()
            .Build();
        // פתיחת החיבור בפועל.
        await hub.StartAsync();
    }

    // פעולה ראשית של כפתור Create.
    // #create-room #solo-game #groups: creates the room, saves it, and moves the host into lobby/play flow.
    private async Task CreateRoomAsync()
    {
        // מאפסים שגיאה קודמת כדי להתחיל ניסיון חדש נקי.
        Error = "";
        // מאפסים מצביע חדר קודם.
        CreatedRoom = null;

        // אם אין מזהה משתמש בסשן, מנסים לשחזרו מה-cookie דרך JS.
        if (Session.CurrentUserId is null)
        {
            await EnsureAuthAsync();
        }

        // בלי משתמש מאומת אי אפשר ליצור חדר.
        if (Session.CurrentUserId is null)
        {
            Error = "You must be logged in to create a room.";
            return;
        }

        // #room-name-validation #create-room-validation #validation
        // ולידציה: שם חדר חובה.
        if (string.IsNullOrWhiteSpace(RoomName))
        {
            Error = "Room name is required.";
            return;
        }

        // יצירת חדר במסד לפי שם/Host/ציבורי/נושא.
        var room = await roomDB.CreateRoomAsync(RoomName, Session.CurrentUserId.Value, IsPublic, SelectedTopicId);
        // אם יצירה נכשלה - מציגים שגיאה.
        if (room is null)
        {
            Error = "Failed to create room.";
            return;
        }

        // שומרים מקומית את החדר שנוצר.
        CreatedRoom = room;

        // אם החדר ציבורי ויש חיבור hub, מודיעים לכל הלקוחות לעדכן רשימת חדרים ציבוריים.
        if (IsPublic && hub is not null)
            await hub.InvokeAsync("PublicRoomChanged");

        // מוסיפים את יוצר החדר לרשימת משתתפים בתור Host.
        await roomDB.JoinRoomAsync(room.RoomID, Session.CurrentUserId.Value, "Host");

        // מעבר אוטומטי ללובי של החדר לפי RoomCode.
        Nav.NavigateTo($"/lobby/{room.RoomCode}", true);
    }

    // ניקוי משאבים כשיוצאים מהעמוד: סגירה מסודרת של SignalR hub.
    public async ValueTask DisposeAsync()
    {
        if (hub is not null)
        {
            // עצירה בטוחה (עם try) כדי לא להפיל את המסך אם החיבור כבר נסגר.
            try { await hub.StopAsync(); } catch { }
            // שחרור אובייקט החיבור מהזיכרון.
            await hub.DisposeAsync();
        }
    }

    // ניסיון שחזור אימות משתמש דרך פונקציית JS auth.me (מחזירה userId מה-cookie/session).
    // #cookie #login #create-room: re-checks auth from the browser if the session cache is empty.
    private async Task EnsureAuthAsync()
    {
        // אם כבר יש משתמש בסשן, לא צריך פעולה נוספת.
        if (Session.CurrentUserId is not null)
            return;

        // קריאה ל-JS כדי לקבל מזהה משתמש מחובר.
        var uid = await JS.InvokeAsync<int>("auth.me");
        // אם חזר מזהה תקף, שומרים אותו בסשן בצד הלקוח.
        if (uid > 0)
            Session.CurrentUserId = uid;
    }
}









