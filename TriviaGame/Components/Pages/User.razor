@page "/user"
@inherits AuthPageBase
@using Models
@using DBL
@rendermode InteractiveServer

@* #user #profile #stats #password #account #logout *@
@* מסך המשתמש: כאן רואים פרטי חשבון, מידע אישי, ולעיתים נתוני פרופיל וסטטוס. *@

<style>
    .wrap {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 25%, #fecfef 50%, #fad0c4 75%, #ffd1ff 100%);
        background-attachment: fixed;
        color: #333;
        font-family: 'Comic Neue', cursive;
        position: relative;
        overflow: hidden;
        padding: 20px;
    }

    .wrap::before {
        content: "👤";
        position: absolute;
        font-size: 4em;
        animation: float 3s ease-in-out infinite;
        top: 5%;
        left: 5%;
        opacity: 0.6;
    }

    .wrap::after {
        content: "🔐";
        position: absolute;
        font-size: 3em;
        animation: float 4s ease-in-out infinite reverse;
        top: 10%;
        right: 8%;
        opacity: 0.5;
    }

    .card {
        width: 620px;
        max-width: 95%;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 240, 245, 0.95) 100%);
        border: 5px solid #ff69b4;
        border-radius: 35px;
        padding: 40px;
        box-shadow: 0 15px 40px rgba(255, 20, 147, 0.4), 0 0 60px rgba(255, 182, 193, 0.3);
        backdrop-filter: blur(10px);
        position: relative;
        z-index: 1;
        animation: pulse-glow 3s ease-in-out infinite;
        transform-style: preserve-3d;
    }

    .title {
        font-size: 2.3rem;
        font-family: 'Fredoka One', cursive;
        color: #ff1493;
        text-shadow: 3px 3px 0px #ff69b4, 6px 6px 10px rgba(255, 20, 147, 0.4);
        margin-bottom: 10px;
        letter-spacing: 2px;
        animation: float 2s ease-in-out infinite;
        text-align: center;
    }

    .sub {
        margin-bottom: 20px;
        opacity: 0.8;
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.1em;
        color: #666;
        text-align: center;
    }

    .section {
        margin-top: 15px;
        padding: 20px;
        border-radius: 25px;
        background: rgba(255, 240, 245, 0.7);
        border: 3px dashed #ffb6c1;
    }

    .section-title {
        font-family: 'Fredoka One', cursive;
        font-size: 1.3em;
        color: #ff1493;
        margin-bottom: 10px;
        letter-spacing: 1px;
    }

    .in {
        width: 100%;
        padding: 15px 20px;
        margin: 10px 0;
        border-radius: 20px;
        border: 3px solid #ffb6c1;
        background: rgba(255, 255, 255, 0.9);
        color: #333;
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.05em;
        transition: all 0.3s ease;
        box-shadow: inset 0 2px 5px rgba(0, 0, 0, 0.1);
    }

    .in:focus {
        outline: none;
        border-color: #ff1493;
        box-shadow: 0 0 20px rgba(255, 20, 147, 0.5), inset 0 2px 5px rgba(0, 0, 0, 0.1);
        transform: scale(1.02);
        background: #fff;
    }

    .in.invalid {
        border-color: #ff4757 !important;
        box-shadow: 0 0 20px rgba(255, 71, 87, 0.5) !important;
        animation: wiggle 0.5s ease;
    }

    .btn {
        width: 100%;
        padding: 14px;
        border: 4px solid #ff1493;
        border-radius: 25px;
        background: linear-gradient(135deg, #ff6b9d 0%, #ff8fab 50%, #ffa8c5 100%);
        color: #fff;
        font-family: 'Fredoka One', cursive;
        font-weight: 700;
        font-size: 1.1em;
        margin-top: 8px;
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 2px;
        box-shadow: 0 8px 20px rgba(255, 20, 147, 0.4);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .btn::before {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.3);
        transform: translate(-50%, -50%);
        transition: width 0.6s, height 0.6s;
    }

    .btn:hover::before {
        width: 350px;
        height: 350px;
    }

    .btn:hover {
        transform: translateY(-4px) scale(1.03);
        box-shadow: 0 12px 30px rgba(255, 20, 147, 0.6);
        animation: bounce 0.6s ease;
    }

    .btn2 {
        width: 100%;
        padding: 14px;
        border-radius: 25px;
        border: 4px solid #ffb6c1;
        cursor: pointer;
        font-family: 'Fredoka One', cursive;
        font-weight: 700;
        font-size: 1.1em;
        background: rgba(255, 182, 193, 0.3);
        color: #ff1493;
        text-transform: uppercase;
        letter-spacing: 2px;
        box-shadow: 0 5px 15px rgba(255, 182, 193, 0.4);
        transition: all 0.3s ease;
        margin-top: 10px;
    }

    .btn2:hover {
        transform: translateY(-3px) scale(1.03);
        box-shadow: 0 8px 25px rgba(255, 182, 193, 0.6);
        border-color: #ff1493;
        background: rgba(255, 182, 193, 0.5);
    }

    .err {
        color: #ff4757;
        margin-top: 10px;
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.05em;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
        animation: wiggle 0.5s ease;
    }

    .ok {
        color: #2ed573;
        margin-top: 10px;
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.05em;
    }
</style>

@if (Session.CurrentUserId is null)
{
    @* אם אין משתמש מחובר עדיין - מציגים מסך טעינה פשוט *@
    <div class="wrap"><div class="card">Loading...</div></div>
}
else
{
    @* אם המשתמש מחובר - מציגים את טופס החשבון *@
    <div class="wrap">
        <div class="card">
            <div class="title">Account</div>
            <div class="sub">Update your profile and password.</div>

            @* אזור עדכון פרטי פרופיל *@
            <div class="section">
                <div class="section-title">Profile</div>
                <input class="in @(UsernameInvalid ? "invalid" : "")" @bind="Username" placeholder="Username" />
                <input class="in @(FullNameInvalid ? "invalid" : "")" @bind="FullName" placeholder="Full name" />
                <input class="in @(EmailInvalid ? "invalid" : "")" @bind="Email" type="email" placeholder="Email" />
                <button class="btn" @onclick="SaveProfileAsync">Save Profile</button>
                @if (!string.IsNullOrWhiteSpace(ProfileStatus))
                {
                    <div class="@(ProfileStatus.StartsWith("✅") ? "ok" : "err")">@ProfileStatus</div>
                }
            </div>

            @* אזור עדכון סיסמה *@
            <div class="section">
                <div class="section-title">Change Password</div>
                <input class="in @(CurrentPasswordInvalid ? "invalid" : "")" @bind="CurrentPassword" type="password" placeholder="Current password" />
                <input class="in @(NewPasswordInvalid ? "invalid" : "")" @bind="NewPassword" type="password" placeholder="New password" />
                <input class="in @(ConfirmPasswordInvalid ? "invalid" : "")" @bind="ConfirmPassword" type="password" placeholder="Confirm new password" />
                <button class="btn" @onclick="ChangePasswordAsync">Update Password</button>
                @if (!string.IsNullOrWhiteSpace(PasswordStatus))
                {
                    <div class="@(PasswordStatus.StartsWith("✅") ? "ok" : "err")">@PasswordStatus</div>
                }
            </div>

            @* חזרה לתפריט הראשי *@
            <button class="btn2" @onclick="@(() => Nav.NavigateTo("/menu", true))">Back to Menu</button>
        </div>
    </div>
}

@code {
    // שם משתמש שהוזן/נטען מהשרת.
    private string Username = "";
    // שם מלא שהוזן/נטען מהשרת.
    private string FullName = "";
    // אימייל שהוזן/נטען מהשרת.
    private string Email = "";

    // סיסמה נוכחית (לשינוי סיסמה).
    private string CurrentPassword = "";
    // סיסמה חדשה.
    private string NewPassword = "";
    // אימות סיסמה חדשה.
    private string ConfirmPassword = "";

    // הודעת סטטוס לאזור הפרופיל.
    private string ProfileStatus = "";
    // הודעת סטטוס לאזור הסיסמה.
    private string PasswordStatus = "";

    // דגל ויזואלי: שם משתמש לא תקין.
    private bool UsernameInvalid = false;
    // דגל ויזואלי: שם מלא לא תקין.
    private bool FullNameInvalid = false;
    // דגל ויזואלי: אימייל לא תקין.
    private bool EmailInvalid = false;
    // דגל ויזואלי: סיסמה נוכחית לא תקינה.
    private bool CurrentPasswordInvalid = false;
    // דגל ויזואלי: סיסמה חדשה לא תקינה.
    private bool NewPasswordInvalid = false;
    // דגל ויזואלי: אימות סיסמה לא תקין.
    private bool ConfirmPasswordInvalid = false;

    // עותק שם משתמש מקורי כדי לזהות אם המשתמש שינה אותו.
    private string OriginalUsername = "";
    // עותק אימייל מקורי כדי לזהות אם המשתמש שינה אותו.
    private string OriginalEmail = "";

    // אובייקט גישה למסד נתוני משתמשים.
    private readonly UserDB userDB = new();
    // הגנה מפני טעינה כפולה של נתוני המשתמש.
    private bool Loaded = false;

    // נטען פעם אחת אחרי אימות משתמש ומביא את נתוני החשבון למסך.
    // #profile #password: loads the current user's profile and password state.
    protected override async Task OnAuthedAsync()
    {
        // אם כבר טענו בעבר - יוצאים ולא טוענים שוב.
        if (Loaded)
            return;

        // מסמנים שטעינה בוצעה.
        Loaded = true;

        // מעתיקים את מזהה המשתמש רק לאחר בדיקה כדי לא להעביר ערך nullable לשכבת ה-DB.
        if (Session.CurrentUserId is not int userId)
        {
            Nav.NavigateTo("/login", true);
            return;
        }

        // מביאים את המשתמש הנוכחי לפי מזהה סשן.
        var user = await userDB.GetByIdAsync(userId);
        // אם לא נמצא משתמש - מחזירים למסך התחברות.
        if (user is null)
        {
            Nav.NavigateTo("/login", true);
            return;
        }

        // ממלאים את הטופס מהנתונים הקיימים במסד.
        Username = user.Username;
        FullName = user.FullName;
        Email = user.Email;
        // שומרים ערכים מקוריים לצורך בדיקות כפילות רק אם באמת שונה.
        OriginalUsername = user.Username;
        OriginalEmail = user.Email;
    }

    // מאפס דגלים והודעה של אזור הפרופיל לפני ולידציה חדשה.
    private void ResetProfileValidation()
    {
        UsernameInvalid = false;
        FullNameInvalid = false;
        EmailInvalid = false;
        ProfileStatus = "";
    }

    // מאפס דגלים והודעה של אזור הסיסמה לפני ולידציה חדשה.
    private void ResetPasswordValidation()
    {
        CurrentPasswordInvalid = false;
        NewPasswordInvalid = false;
        ConfirmPasswordInvalid = false;
        PasswordStatus = "";
    }

    // שומר את נתוני הפרופיל אחרי בדיקות תקינות וכפילויות.
    // #profile: saves display-name and account changes.
    private async Task SaveProfileAsync()
    {
        // איפוס שגיאות ישנות בתחילת פעולה.
        ResetProfileValidation();

        // בודקים תקינות שם משתמש לפי כללי המערכת.
        var (usernameValid, usernameError) = ValidationHelper.ValidateUsername(Username);
        if (!usernameValid)
        {
            UsernameInvalid = true;
            ProfileStatus = $"❌ {usernameError}";
            return;
        }

        // בודקים תקינות שם מלא.
        var (fullNameValid, fullNameError) = ValidationHelper.ValidateFullName(FullName);
        if (!fullNameValid)
        {
            FullNameInvalid = true;
            ProfileStatus = $"❌ {fullNameError}";
            return;
        }

        // אימייל חובה.
        if (string.IsNullOrWhiteSpace(Email))
        {
            EmailInvalid = true;
            ProfileStatus = "❌ Email is required.";
            return;
        }

        // אימייל חייב להיות בפורמט חוקי.
        if (!ValidationHelper.IsValidEmail(Email))
        {
            EmailInvalid = true;
            ProfileStatus = "❌ Please enter a valid email address.";
            return;
        }

        // ניקוי קלט כדי למנוע תווים/רווחים לא רצויים.
        Username = ValidationHelper.SanitizeInput(Username, 50);
        FullName = ValidationHelper.SanitizeInput(FullName, 100);
        Email = ValidationHelper.SanitizeInput(Email, 100).ToLowerInvariant().Trim();

        // אם אין משתמש מחובר - אין מה לשמור.
        if (Session.CurrentUserId is null)
            return;

        // אם שם המשתמש השתנה, בודקים שאין משתמש אחר עם אותו שם.
        if (!Username.Equals(OriginalUsername, StringComparison.OrdinalIgnoreCase))
        {
            var existingUsername = await userDB.GetByUsernameAsync(Username);
            if (existingUsername is not null && existingUsername.UserID != Session.CurrentUserId.Value)
            {
                UsernameInvalid = true;
                ProfileStatus = "❌ Username already taken.";
                return;
            }
        }

        // אם האימייל השתנה, בודקים שאין משתמש אחר עם אותו אימייל.
        if (!Email.Equals(OriginalEmail, StringComparison.OrdinalIgnoreCase))
        {
            var existingEmail = await userDB.GetByEmailAsync(Email);
            if (existingEmail is not null && existingEmail.UserID != Session.CurrentUserId.Value)
            {
                EmailInvalid = true;
                ProfileStatus = "❌ Email already registered.";
                return;
            }
        }

        // ניסיון שמירה למסד.
        try
        {
            var ok = await userDB.UpdateProfileAsync(Session.CurrentUserId.Value, Username, FullName, Email);
            // אם עדכון נכשל במסד - מחזירים הודעת שגיאה.
            if (!ok)
            {
                ProfileStatus = "❌ Failed to update profile.";
                return;
            }

            // אם הצליח - מעדכנים את הערכים המקוריים ומראים הצלחה.
            OriginalUsername = Username;
            OriginalEmail = Email;
            ProfileStatus = "✅ Profile updated.";
        }
        // שגיאה לוגית (למשל כלל עסקי) מוצגת למשתמש.
        catch (InvalidOperationException ex)
        {
            ProfileStatus = $"❌ {ex.Message}";
        }
        // שגיאה כללית לא צפויה.
        catch
        {
            ProfileStatus = "❌ An error occurred. Please try again later.";
        }
    }

    // מבצע החלפת סיסמה אחרי בדיקות ולידציה ואימות סיסמה נוכחית.
    // #password: updates the current user's password.
    private async Task ChangePasswordAsync()
    {
        // איפוס שגיאות ישנות בתחילת פעולה.
        ResetPasswordValidation();

        // סיסמה נוכחית היא שדה חובה.
        if (string.IsNullOrWhiteSpace(CurrentPassword))
        {
            CurrentPasswordInvalid = true;
            PasswordStatus = "❌ Current password is required.";
            return;
        }

        // בודקים שהסיסמה החדשה עומדת בכללי המורכבות.
        var (passwordValid, passwordError) = ValidationHelper.ValidatePassword(NewPassword);
        if (!passwordValid)
        {
            NewPasswordInvalid = true;
            PasswordStatus = $"❌ {passwordError}";
            return;
        }

        // אימות סיסמה חדשה הוא שדה חובה.
        if (string.IsNullOrWhiteSpace(ConfirmPassword))
        {
            ConfirmPasswordInvalid = true;
            PasswordStatus = "❌ Please confirm your new password.";
            return;
        }

        // שתי סיסמאות חדשות חייבות להיות זהות בדיוק.
        if (!NewPassword.Equals(ConfirmPassword, StringComparison.Ordinal))
        {
            ConfirmPasswordInvalid = true;
            PasswordStatus = "❌ Passwords do not match.";
            return;
        }

        // בלי משתמש מחובר לא ניתן לעדכן סיסמה.
        if (Session.CurrentUserId is null)
            return;

        // ניסיון אימות ועדכון סיסמה.
        try
        {
            // מביאים משתמש כדי לאמת את הסיסמה הנוכחית.
            var user = await userDB.GetByIdAsync(Session.CurrentUserId.Value);
            // אם המשתמש לא נמצא או שהסיסמה הנוכחית שגויה - עוצרים.
            if (user is null || !PasswordHelper.Verify(CurrentPassword.Trim(), user.PasswordHash))
            {
                CurrentPasswordInvalid = true;
                PasswordStatus = "❌ Current password is incorrect.";
                return;
            }

            // שומרים את הסיסמה החדשה לאחר hashing.
            var updated = await userDB.UpdatePasswordAsync(Session.CurrentUserId.Value, PasswordHelper.Hash(NewPassword.Trim()));
            // אם העדכון נכשל במסד - מחזירים שגיאה.
            if (!updated)
            {
                PasswordStatus = "❌ Failed to update password.";
                return;
            }

            // מנקים את שדות הסיסמה מהמסך אחרי הצלחה.
            CurrentPassword = "";
            NewPassword = "";
            ConfirmPassword = "";
            PasswordStatus = "✅ Password updated.";
        }
        // שגיאה כללית לא צפויה.
        catch
        {
            PasswordStatus = "❌ An error occurred. Please try again later.";
        }
    }

}






