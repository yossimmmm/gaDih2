@page "/assistant"
@inherits AuthPageBase
@using TriviaGame.Services
@inject GeminiAdviceService GeminiService
@rendermode InteractiveServer

<style>
    .assistant-wrap {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
        background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 25%, #fecfef 50%, #fad0c4 75%, #ffd1ff 100%);
    }

    .assistant-card {
        width: 900px;
        max-width: 96%;
        height: 82vh;
        background: rgba(255, 255, 255, 0.95);
        border: 4px solid #ff69b4;
        border-radius: 28px;
        padding: 18px;
        display: grid;
        grid-template-rows: auto 1fr auto;
        gap: 12px;
    }

    .assistant-title {
        font-size: 1.9rem;
        font-family: 'Fredoka One', cursive;
        color: #ff1493;
    }

    .chat-box {
        border: 2px dashed #ffb6c1;
        border-radius: 16px;
        padding: 12px;
        overflow-y: auto;
        background: rgba(255, 240, 245, 0.7);
    }

    .msg {
        margin: 8px 0;
        padding: 10px 12px;
        border-radius: 12px;
        white-space: pre-wrap;
        line-height: 1.4;
    }

    .msg.user {
        background: #ffd6ea;
        border: 1px solid #ff9ac6;
    }

    .msg.bot {
        background: #ffffff;
        border: 1px solid #ddd;
    }

    .composer {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 8px;
    }

    .composer textarea {
        width: 100%;
        min-height: 70px;
        max-height: 140px;
        border-radius: 12px;
        border: 2px solid #ffb6c1;
        padding: 10px;
        resize: vertical;
        font-family: inherit;
    }

    .send-btn {
        border: 3px solid #ff1493;
        border-radius: 14px;
        background: linear-gradient(135deg, #ff6b9d 0%, #ff8fab 50%, #ffa8c5 100%);
        color: #fff;
        font-weight: 700;
        padding: 0 16px;
        cursor: pointer;
    }

    .controls {
        display: flex;
        gap: 8px;
    }

    .back-btn {
        border: 2px dashed #ff69b4;
        background: rgba(255, 182, 193, 0.25);
        color: #ff1493;
        border-radius: 10px;
        padding: 8px 12px;
        cursor: pointer;
        font-weight: 700;
    }

    @@media (max-width: 640px) {
        .assistant-wrap { padding: 8px; }
        .assistant-card {
            width: 100%;
            max-width: none;
            height: 92vh;
            border-radius: 16px;
            padding: 10px;
        }
        .assistant-title { font-size: 1.45rem; }
        .composer { grid-template-columns: 1fr; }
        .send-btn { padding: 12px; }
    }
</style>

@if (Session.CurrentUserId is null)
{
    <div class="assistant-wrap"><div class="assistant-card">Loading...</div></div>
}
else
{
    <div class="assistant-wrap">
        <div class="assistant-card">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;">
                <div class="assistant-title">Gemini Personal Assistant</div>
                <div class="controls">
                    @* כפתור Back: מחזיר לתפריט הראשי ע"י ניווט ל-/menu ורענון מלא *@
                    <button class="back-btn" @onclick="@(() => Nav.NavigateTo("/menu", true))" title="Navigates back to Menu and reloads page state">Back</button>
                    @* כפתור Clear: מנקה את היסטוריית הצ'אט ומוסיף הודעת פתיחה חדשה *@
                    <button class="back-btn" @onclick="ClearChat" title="Clears all current chat messages">Clear</button>
                </div>
            </div>

            <div class="chat-box">
                @* לולאה שמציגה את כל ההודעות לפי הסדר השמור בזיכרון Messages *@
                @foreach (var msg in Messages)
                {
                    @* כל הודעה מקבלת עיצוב שונה לפי role: user/assistant *@
                    <div class="msg @(msg.Role == "user" ? "user" : "bot")">
                        @* כותרת קטנה לכל הודעה: You או Gemini *@
                        <strong>@(msg.Role == "user" ? "You" : "Gemini"):</strong>
                        @* טקסט ההודעה עצמה *@
                        <div>@msg.Text</div>
                    </div>
                }
            </div>

            <div class="composer">
                @* תיבת קלט לשאלה. disabled בזמן שליחה כדי למנוע שינוי מצב באמצע בקשה *@
                <textarea @bind="DraftMessage" placeholder="Ask about your wins, games, accuracy, progress..." disabled="@IsSending"></textarea>
                @* כפתור Send: שולח את הטקסט ל-SendAsync ומושבת בזמן בקשה פעילה *@
                <button class="send-btn" @onclick="SendAsync" disabled="@IsSending" title="Sends your question to Gemini with your personal game statistics context">
                    @(IsSending ? "Sending..." : "Send")
                </button>
            </div>

        </div>
    </div>
}

@code {
    // הסבר עמוד: לוגיקת Assistant וניהול מצב המסך.
    // רשימת כל הפניות בצ'אט לפי סדר כרונולוגי (גם משתמש וגם עוזר).
    private readonly List<GeminiChatTurn> Messages = new();
    // הטקסט הנוכחי שבתיבת הכתיבה לפני שליחה.
    private string DraftMessage = "";
    // דגל מצב: האם בקשת שליחה פעילה כרגע (לנעילת UI בזמן API).
    private bool IsSending;

    // רץ אחרי אימות משתמש. מוסיף הודעת פתיחה פעם אחת לכל טעינת עמוד חדשה.
    protected override Task OnAuthedAsync()
    {
        // אם עדיין אין היסטוריה, נתחיל בהודעה ראשונית שמסבירה מה אפשר לשאול.
        if (Messages.Count == 0)
        {
            Messages.Add(new GeminiChatTurn(
                "assistant",
                "Hi. I can answer using your personal trivia data (wins, games, accuracy, recent results)."));
        }

        return Task.CompletedTask;
    }

    // פונקציית שליחה ראשית: מופעלת בלחיצה על Send.
    private async Task SendAsync()
    {
        // תנאי יציאה 1: אין משתמש מחובר או שיש כבר בקשה פעילה.
        if (Session.CurrentUserId is null || IsSending)
            return;

        // ניקוי רווחים מיותרים ובדיקה שההודעה לא ריקה.
        var text = (DraftMessage ?? "").Trim();
        if (string.IsNullOrWhiteSpace(text))
            return;

        // עדכון UI מיידי: מכניסים הודעת משתמש לפני ההמתנה לתשובת Gemini.
        IsSending = true;
        Messages.Add(new GeminiChatTurn("user", text));
        DraftMessage = "";

        try
        {
            // קריאה לשירות Gemini עם: מזהה משתמש, טקסט השאלה, והיסטוריית צ'אט.
            var reply = await GeminiService.GetPersonalAssistantReplyAsync(
                Session.CurrentUserId.Value,
                text,
                Messages);

            // אם הקריאה הצליחה - מוסיפים תשובה. אחרת - מוסיפים הודעת fallback ידידותית.
            if (reply.Success)
                Messages.Add(new GeminiChatTurn("assistant", reply.Text));
            else
                Messages.Add(new GeminiChatTurn("assistant", reply.ErrorMessage ?? "Assistant is unavailable."));
        }
        catch (Exception ex)
        {
            // טיפול בשגיאה לא צפויה (לדוגמה תקלה ברשת/שרת).
            Messages.Add(new GeminiChatTurn("assistant", $"Error: {ex.Message}"));
        }
        finally
        {
            // שחרור נעילת השליחה בכל מקרה (הצלחה או שגיאה).
            IsSending = false;
        }
    }

    // פונקציה שמאפסת את כל הצ'אט הנוכחי ומחזירה הודעת פתיחה.
    private void ClearChat()
    {
        // מחיקה מלאה של כל ההודעות שנשמרו בזיכרון.
        Messages.Clear();
        // הוספת הודעה התחלתית חדשה כדי שהמסך לא יישאר ריק.
        Messages.Add(new GeminiChatTurn(
            "assistant",
            "Chat cleared. Ask anything about your personal trivia performance."));
    }
}



