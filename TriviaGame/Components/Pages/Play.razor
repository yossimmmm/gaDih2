@page "/play/{RoomCode}"
@inherits AuthPageBase
@using Models
@using System.Threading
@using DBL
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@using System.Linq
@rendermode InteractiveServer
@inject GeminiAdviceService GeminiAdvice

@* #play #question #answer #solo-game #room #scoreboard #results #next-question *@
@* דף המשחק עצמו: כאן רואים שאלה נוכחית, בוחרים תשובה, ומתקדמים לשאלה הבאה או לתוצאות. *@

<style>
    .wrap { 
        min-height: 100vh; 
        display: flex; 
        justify-content: center; 
        align-items: center; 
        background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 25%, #fecfef 50%, #fad0c4 75%, #ffd1ff 100%);
        background-attachment: fixed;
        color: #333; 
        font-family: 'Comic Neue', cursive; 
        position: relative;
        overflow: hidden;
        padding: 20px;
    }
    
    .wrap::before {
        content: "🧠";
        position: absolute;
        font-size: 4em;
        animation: float 3s ease-in-out infinite;
        top: 5%;
        left: 5%;
        opacity: 0.6;
    }
    
    .wrap::after {
        content: "⏱️";
        position: absolute;
        font-size: 3em;
        animation: float 4s ease-in-out infinite reverse;
        top: 10%;
        right: 8%;
        opacity: 0.5;
    }
    
    .card { 
        width: 750px; 
        max-width: 95%;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 240, 245, 0.95) 100%);
        border: 5px solid #ff69b4; 
        border-radius: 35px; 
        padding: 40px; 
        box-shadow: 0 15px 40px rgba(255, 20, 147, 0.4), 0 0 60px rgba(255, 182, 193, 0.3); 
        backdrop-filter: blur(10px);
        position: relative;
        z-index: 1;
        animation: pulse-glow 3s ease-in-out infinite;
        transform-style: preserve-3d;
    }
    
    .card::before {
        content: "🎯";
        position: absolute;
        top: -25px;
        right: -25px;
        font-size: 4em;
        animation: bounce 2s infinite;
        z-index: -1;
    }
    
    .top { 
        display: flex; 
        justify-content: space-between; 
        align-items: center; 
        gap: 15px; 
        margin-bottom: 20px; 
        flex-wrap: wrap;
    }
    
    .title { 
        font-size: 2.3rem; 
        font-family: 'Fredoka One', cursive;
        color: #ff1493; 
        text-shadow: 3px 3px 0px #ff69b4, 6px 6px 10px rgba(255, 20, 147, 0.4);
        letter-spacing: 2px;
        animation: float 2s ease-in-out infinite;
    }
    
    .badge { 
        opacity: 0.9; 
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.1em;
        color: #ff1493;
        padding: 10px 15px;
        background: rgba(255, 182, 193, 0.3);
        border-radius: 15px;
        border: 2px solid #ff69b4;
    }
    
    .q { 
        margin-top: 25px; 
        font-size: 1.5rem; 
        line-height: 1.6; 
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        color: #333;
        padding: 20px;
        background: rgba(255, 240, 245, 0.7);
        border-radius: 20px;
        border: 3px dashed #ffb6c1;
        box-shadow: inset 0 2px 10px rgba(255, 182, 193, 0.3);
    }
    
    .opt { 
        width: 100%; 
        text-align: left; 
        padding: 18px 25px; 
        margin: 12px 0; 
        border-radius: 25px; 
        border: 4px solid #ffb6c1; 
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(255, 240, 245, 0.9)); 
        color: #333; 
        cursor: pointer; 
        font-family: 'Comic Neue', cursive;
        font-weight: 700; 
        font-size: 1.2em;
        transition: all 0.3s ease;
        box-shadow: 0 5px 15px rgba(255, 182, 193, 0.3);
        position: relative;
        overflow: hidden;
    }
    
    .opt::before {
        content: "";
        position: absolute;
        top: 50%;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.5), transparent);
        transition: left 0.5s;
    }
    
    .opt:hover::before {
        left: 100%;
    }
    
    .opt:hover { 
        border-color: #ff1493; 
        transform: translateX(10px) scale(1.03);
        box-shadow: 0 8px 25px rgba(255, 20, 147, 0.5);
        background: linear-gradient(135deg, rgba(255, 255, 255, 1), rgba(255, 240, 245, 1));
        animation: bounce 0.5s ease;
    }
    
    .opt:disabled { 
        opacity: 0.5; 
        cursor: not-allowed; 
        transform: none !important;
        border-color: #ccc;
        background: rgba(200, 200, 200, 0.3);
    }
    
    .row { 
        display: flex; 
        gap: 15px; 
        margin-top: 20px; 
        flex-wrap: wrap;
    }
    
    .btn2 { 
        padding: 15px 25px; 
        border-radius: 25px; 
        border: 4px solid #ffb6c1; 
        cursor: pointer; 
        font-family: 'Fredoka One', cursive;
        font-weight: 800; 
        font-size: 1.1em;
        background: rgba(255, 182, 193, 0.3); 
        color: #ff1493; 
        text-transform: uppercase;
        letter-spacing: 2px;
        box-shadow: 0 5px 15px rgba(255, 182, 193, 0.4);
        transition: all 0.3s ease;
    }
    
    .btn2:hover {
        transform: translateY(-3px) scale(1.05);
        box-shadow: 0 8px 25px rgba(255, 182, 193, 0.6);
        border-color: #ff1493;
        background: rgba(255, 182, 193, 0.5);
        animation: bounce 0.6s ease;
    }
    
    .err { 
        color: #ff4757; 
        margin-top: 15px; 
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.2em;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
        animation: wiggle 0.5s ease;
        padding: 15px;
        background: rgba(255, 71, 87, 0.1);
        border-radius: 15px;
        border: 3px solid #ff4757;
    }
    
    .ok { 
        color: #2ed573; 
        margin-top: 15px; 
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.3em;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
        padding: 15px;
        background: rgba(46, 213, 115, 0.1);
        border-radius: 15px;
        border: 3px solid #2ed573;
        animation: bounce 1s ease infinite;
        text-align: center;
    }

    .advice {
        margin-top: 15px;
        padding: 16px;
        border-radius: 16px;
        border: 3px solid #f39c12;
        background: rgba(243, 156, 18, 0.12);
        color: #7d4b00;
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        line-height: 1.4;
    }
</style>

@if (Session.CurrentUserId is null)
{
    <div class="wrap"><div class="card">Loading...</div></div>
}
else
{
    <div class="wrap">
        <div class="card">
            <div class="top">
                <div class="title">🎯 Trivia</div>
                <div class="badge">Room: @RoomCode</div>
                @if (IsSinglePlayer)
                {
                    <div class="badge">Time Left: @TimeLeftSec s</div>
                }
                @if (!IsSinglePlayer && CurrentQuestion is not null)
                {
                    <div class="badge">Question Time: @QuestionTimeLeftSec s</div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(Status))
            {
                <div class="err">@Status</div>
            }

            @if (CurrentQuestion is null)
            {
                @if (GameFinished || (IsSinglePlayer && TimeExpired))
{
    <div class="q">Game finished.</div>
}
else
{
    <div class="q">Waiting for next question...</div>
}
                @if (IsSinglePlayer)
                {
                    <div class="q">Answered: @AnsweredCount / @TotalQuestions | Unanswered: @UnansweredCount</div>
                }
                <div class="row">
                    @* כפתור View Results: מעבר למסך תוצאות של החדר הנוכחי *@
                    <button class="btn2" @onclick="@(() => Nav.NavigateTo($"/results/{RoomCode}", true))">View Results</button>
                    @* כפתור Back to Menu: יציאה לתפריט הראשי *@
                    <button class="btn2" @onclick="@(() => Nav.NavigateTo("/menu", true))">Back to Menu</button>
                </div>
            }
            else
            {
                <div class="q">@CurrentQuestion.QuestionText</div>
                @if (IsSinglePlayer)
                {
                    <div class="q">Answered: @AnsweredCount / @TotalQuestions | Unanswered: @UnansweredCount</div>
                }

                <div class="row">
                    @* כפתור Ask Gemini Advice: שולח את השאלה הנוכחית ל-Gemini לקבלת רמז *@
                    <button class="btn2"
                            disabled="@(IsAdviceLoading || Answered || (IsSinglePlayer ? TimeExpired : QuestionTimeExpired))"
                            @onclick="AskGeminiAdviceAsync">
                        @(IsAdviceLoading ? "Getting Gemini advice..." : "Ask Gemini Advice")
                    </button>
                </div>
                @if (!string.IsNullOrWhiteSpace(AdviceError))
                {
                    <div class="err">@AdviceError</div>
                }
                @if (!string.IsNullOrWhiteSpace(AdviceText))
                {
                    <div class="advice">@AdviceText</div>
                }

                @foreach (var opt in CurrentQuestion.Options)
                {
                    @* כפתור אופציה לתשובה: שולח OptionID לפונקציית PickOptionAsync *@
                    <button class="opt"
                            disabled="@(Answered || (IsSinglePlayer ? TimeExpired : QuestionTimeExpired))"
                            @onclick="@(() => PickOptionAsync(opt.OptionID))">
                        @opt.OptionText
                    </button>
                }

                @if (Answered && ShowResult)
                {
                    @if (WasCorrect)
                    {
                        <div class="ok">✅ Correct! Great job!</div>
                    }
                    else
                    {
                        <div style="color: #ff4757; margin-top: 15px; font-family: 'Comic Neue', cursive; font-weight: 700; font-size: 1.3em; text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2); padding: 15px; background: rgba(255, 71, 87, 0.1); border-radius: 15px; border: 3px solid #ff4757; text-align: center;">
                            ? Incorrect. Better luck next time!
                        </div>
                    }
                    @if (IsSinglePlayer)
                    {
                        <div style="color: #666; margin-top: 10px; font-family: 'Comic Neue', cursive; font-weight: 700; text-align: center;">➡️ Moving to next question...</div>
                    }
                }
                else if (Answered)
                {
                    <div class="ok">✅ Answer submitted.</div>
                }
                else if (QuestionTimeExpired)
                {
                    <div class="err">⏰ Time is up for this question.</div>
                }

                <div class="row">
                    @* כפתור Back to Lobby: חוזר ללובי עם אישור משתמש אם משחק עדיין בתהליך *@
                    <button class="btn2" @onclick="GoToLobbyAsync">Back to Lobby</button>
                    @* כפתור Exit to Menu: יציאה בטוחה לתפריט/לובי לפי סוג משחק *@
                    <button class="btn2" @onclick="ExitToMenuAsync">Exit to Menu</button>
                </div>

            }
        </div>
    </div>
}

@code {
    // הסבר עמוד: מסך המשחק הפעיל כולל טיימרים, תשובות, עזרה מ-Gemini וסנכרון בזמן אמת

    // פרמטר נתיב שמתקבל מה-URL (קוד חדר)
    [Parameter] public string RoomCode { get; set; } = "";
    // הודעת סטטוס כללית להצגה במסך
    private string Status = "";

    // מזהה פנימי של החדר במסד
    private int RoomId = 0;
    // מזהה שחקן-בחדר (RoomPlayer) עבור המשתמש הנוכחי
    private int RoomPlayerId = 0;
    // דגל מצב משחק יחיד
    private bool IsSinglePlayer = false;
    // כמות שאלות כוללת במשחק
    private int TotalQuestions = 0;
    // כמה שאלות המשתמש כבר ענה
    private int AnsweredCount = 0;
    // כמה שאלות נותרו ללא מענה
    private int UnansweredCount => Math.Max(0, TotalQuestions - AnsweredCount);
    // האם המשתמש סיים את כל השאלות
    private bool GameFinished => TotalQuestions > 0 && AnsweredCount >= TotalQuestions;

    // טיימר כללי למשחק יחיד (60 שניות)
    private int TimeLeftSec = 60;
    // האם הזמן הכללי נגמר
    private bool TimeExpired = false;
    // טיימר לשאלה נוכחית במולטיפלייר
    private int QuestionTimeLeftSec = 15;
    // האם זמן השאלה נגמר
    private bool QuestionTimeExpired = false;

    // אובייקט השאלה הפעילה כרגע
    private Question? CurrentQuestion;
    // האם המשתמש כבר ענה על השאלה הנוכחית
    private bool Answered = false;
    // האם להציג תוצאת Correct/Incorrect מייד אחרי תשובה
    private bool ShowResult = false;
    // האם התשובה האחרונה הייתה נכונה
    private bool WasCorrect = false;

    // טקסט העצה מ-Gemini
    private string AdviceText = "";
    // שגיאה מעצת Gemini (אם הייתה)
    private string AdviceError = "";
    // דגל טעינה של בקשת עצה
    private bool IsAdviceLoading = false;

    // DB חדרים
    private readonly RoomDB roomDB = new();
    // DB משחק (שאלות/תשובות/תוצאות)
    private readonly GameDB gameDB = new();
    // מניעת אתחול כפול של העמוד
    private bool Loaded = false;

    // חיבור SignalR
    private HubConnection? hub;
    // טיימר מעבר אוטומטי לשאלה הבאה (במשחק יחיד)
    private System.Threading.Timer? autoAdvanceTimer;
    // טיימר ספירה לאחור למשחק יחיד
    private System.Threading.Timer? countdownTimer;
    // טיימר לשאלה בודדת במולטיפלייר
    private System.Threading.Timer? questionTimer;
    // heartbeat תקופתי כדי לשמור חדר פעיל
    private System.Threading.Timer? heartbeatTimer;
    private bool _disposing = false;

    // נקודת כניסה אחרי אימות משתמש
    // #play: entry point for loading a room and starting the live game flow.
    protected override async Task OnAuthedAsync()
    {
        // אם כבר אתחלנו, לא מאתחלים שוב
        if (Loaded)
            return;
        Loaded = true;

        // המשחק דורש משתמש מחובר; מכאן והלאה משתמשים במזהה שכבר נבדק ואינו nullable.
        if (Session.CurrentUserId is not int userId)
        {
            SafeNavigateTo("/login", true);
            return;
        }

        // שליפת חדר לפי קוד מה-URL
        var room = await roomDB.GetRoomByCodeAsync(RoomCode.Trim().ToUpperInvariant());
        if (room is null)
        {
            Status = "Room not found.";
            return;
        }
        // שמירת מזהה חדר פנימי
        RoomId = room.RoomID;

        // הצטרפות המשתמש לחדר (או החזרת הרשומה אם כבר בפנים)
        var joined = await roomDB.JoinRoomAsync(RoomId, userId, $"Player{userId}");
        if (joined is null)
        {
            Status = "Failed to join room.";
            return;
        }
        // שמירת מזהה שחקן-בחדר
        RoomPlayerId = joined.RoomPlayerID;

        // בדיקה אם זה חדר של שחקן יחיד (לפי כמות שחקנים)
        var players = await roomDB.GetPlayersAsync(RoomId);
        IsSinglePlayer = players.Count == 1;
        // שליפת מספר שאלות כולל
        TotalQuestions = await gameDB.GetRoomQuestionCountAsync(RoomId);
        // אם משחק יחיד, מאתחלים טיימר כללי
        if (IsSinglePlayer)
        {
            TimeLeftSec = 60;
            TimeExpired = false;
        }

        // בניית חיבור SignalR לחדר
        hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/game"))
            .WithAutomaticReconnect()
            .Build();

        // מאזין לאירוע שאלה הבאה
        hub.On<string>("NextQuestion", async _ =>
        {
            await LoadCurrentQuestionAsync();
            await InvokeAsync(StateHasChanged);
        });

        // מאזין לאירוע תשובה נשלחה
        hub.On<string>("AnswerSubmitted", async _ =>
        {
            // במולטיפלייר מרעננים שאלה; במשחק יחיד יש auto-advance נפרד
            if (!IsSinglePlayer)
            {
                await LoadCurrentQuestionAsync();
                await InvokeAsync(StateHasChanged);
            }
        });

        // פתיחת החיבור בפועל
        await hub.StartAsync();
        // שיוך החיבור לקבוצת החדר
        await hub.InvokeAsync("JoinRoomGroup", RoomCode, userId);

        // heartbeat כל 10 שניות כדי לשמור חדר פעיל
        heartbeatTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                if (hub is not null)
                    await hub.InvokeAsync("RoomHeartbeat", RoomCode);
            }
            catch { }
        }, null, 0, 10000);

        // מאזין לסגירת חדר מצד המארח
        hub.On<string>("RoomClosed", async _ =>
        {
            Status = "Room closed by host.";
            await InvokeAsync(StateHasChanged);
            await Task.Delay(1200);
            await InvokeAsync(() => SafeNavigateTo("/menu", true));
        });

        // טעינת שאלה ראשונה וסטטיסטיקה ראשונית
        await LoadCurrentQuestionAsync();
        await UpdateStatsAsync();
        // התחלת טיימר כללי אם משחק יחיד
        if (IsSinglePlayer)
            StartCountdown();
    }

    // טעינת השאלה הנוכחית למסך
    // #question: loads the current question and prepares answer state.
    private async Task LoadCurrentQuestionAsync()
    {
        // איפוס סטטוס ותצוגות עזר לפני טעינה חדשה
        Status = "";
        Answered = false;
        AdviceText = "";
        AdviceError = "";
        IsAdviceLoading = false;

        // שליפת שאלה פעילה מהשרת
        CurrentQuestion = await gameDB.GetCurrentQuestionAsync(RoomId);
        if (CurrentQuestion is null)
        {
            // אם אין שאלה פעילה יותר, שומרים תוצאות
            await gameDB.SaveRoomResultsAsync(RoomId);
            return;
        }

        // בדיקה אם המשתמש כבר ענה על השאלה הזאת
        var already = await gameDB.HasPlayerAnsweredAsync(RoomId, RoomPlayerId, CurrentQuestion.QuestionID);
        Answered = already;
        // איפוס דגל פקיעת זמן לשאלה
        QuestionTimeExpired = false;
        // במולטיפלייר מפעילים טיימר שאלה
        if (!IsSinglePlayer)
            StartQuestionTimer();
    }

    // רענון כמות תשובות שהמשתמש ענה
    private async Task UpdateStatsAsync()
    {
        AnsweredCount = await gameDB.GetPlayerAnswerCountAsync(RoomId, RoomPlayerId);
    }

    // טיימר ספירה לאחור למשחק יחיד
    private void StartCountdown()
    {
        // אתחול ערכי התחלה
        TimeLeftSec = 60;
        TimeExpired = false;
        // ניקוי טיימר קודם אם היה
        countdownTimer?.Dispose();
        // יצירת טיימר חדש שכל שנייה מוריד 1
        countdownTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                if (TimeExpired)
                    return;

                TimeLeftSec = Math.Max(0, TimeLeftSec - 1);
                if (TimeLeftSec == 0)
                {
                    TimeExpired = true;
                    Status = "Time is up. Game over.";
                    await gameDB.SaveRoomResultsAsync(RoomId);
                    SafeNavigateTo($"/results/{RoomCode}", true);
                }

                StateHasChanged();
            });
        }, null, 1000, 1000);
    }

    // טיימר לשאלה נוכחית במולטיפלייר
    private void StartQuestionTimer()
    {
        // אם אין שאלה - אין מה לספור
        if (CurrentQuestion is null)
            return;

        // איפוס דגל פקיעה
        QuestionTimeExpired = false;
        // ניקוי טיימר קודם אם היה
        questionTimer?.Dispose();

        // קביעת זמן התחלה (ממסד או עכשיו)
        var startedAt = CurrentQuestion.StartedAt ?? DateTime.Now;
        // קביעת time limit (ברירת מחדל 15)
        var timeLimit = CurrentQuestion.TimeLimitSec > 0 ? CurrentQuestion.TimeLimitSec : 15;
        // חישוב זמן נותר מיידי
        QuestionTimeLeftSec = Math.Max(0, timeLimit - (int)Math.Floor((DateTime.Now - startedAt).TotalSeconds));

        // אם כבר נגמר, מפעילים מעבר לשאלה הבאה
        if (QuestionTimeLeftSec <= 0)
        {
            QuestionTimeExpired = true;
            _ = OnQuestionExpiredAsync();
            return;
        }

        // טיימר שמתעדכן כל שנייה
        questionTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                if (QuestionTimeExpired)
                    return;

                var remaining = timeLimit - (int)Math.Floor((DateTime.Now - startedAt).TotalSeconds);
                QuestionTimeLeftSec = Math.Max(0, remaining);

                if (QuestionTimeLeftSec <= 0)
                {
                    QuestionTimeExpired = true;
                    await OnQuestionExpiredAsync();
                }

                StateHasChanged();
            });
        }, null, 1000, 1000);
    }

    // מה עושים כשזמן שאלה נגמר
    private async Task OnQuestionExpiredAsync()
    {
        // במולטיפלייר מבקשים מהשרת להתקדם לשאלה הבאה
        if (hub is not null && !IsSinglePlayer)
            await hub.InvokeAsync("NextQuestion", RoomCode);
    }

    // בחירת אופציה על ידי המשתמש
    // #question #answer: handles the player's click on an option and stores the answer.
    private async Task PickOptionAsync(int optionId)
    {
        // מניעת שליחה במצבים לא תקינים
        if (Answered || CurrentQuestion is null || TimeExpired || QuestionTimeExpired)
            return;

        // בדיקה מקומית אם האופציה שנבחרה היא הנכונה (לתצוגה מיידית)
        var selectedOption = CurrentQuestion.Options.FirstOrDefault(o => o.OptionID == optionId);
        WasCorrect = selectedOption?.IsCorrect ?? false;

        // שליחת תשובה למסד
        var ok = await gameDB.SubmitAnswerAsync(RoomPlayerId, CurrentQuestion.QuestionID, optionId);
        if (!ok)
        {
            Status = "Failed to submit answer.";
            return;
        }

        // עדכון מצב מסך אחרי הצלחת שליחה
        Answered = true;
        ShowResult = true;
        await UpdateStatsAsync();

        // במשחק יחיד אם סיימנו הכל - שומרים תוצאות
        if (IsSinglePlayer && GameFinished)
            await gameDB.SaveRoomResultsAsync(RoomId);

        // עדכון שאר משתתפים שהוגשה תשובה
        if (hub is not null)
            await hub.InvokeAsync("AnswerSubmitted", RoomCode);

        // במשחק יחיד: מעבר אוטומטי לשאלה הבאה אחרי השהיה קצרה
        if (IsSinglePlayer)
        {
            autoAdvanceTimer?.Dispose();
            autoAdvanceTimer = new System.Threading.Timer(async _ =>
            {
                await InvokeAsync(async () =>
                {
                    ShowResult = false;
                    await Task.Delay(500);
                    await LoadCurrentQuestionAsync();
                    await UpdateStatsAsync();
                    StateHasChanged();
                });
            }, null, 2500, System.Threading.Timeout.Infinite);
        }
    }

    // בקשת עצת Gemini לשאלה הנוכחית
    // #question: asks Gemini for advice on the current question.
    private async Task AskGeminiAdviceAsync()
    {
        // מונעים קריאה אם אין שאלה/בתהליך/כבר ענה/נגמר זמן
        if (CurrentQuestion is null || IsAdviceLoading || Answered || TimeExpired || QuestionTimeExpired)
            return;

        // איפוס טקסט עזרה ושגיאות קודמות
        AdviceError = "";
        AdviceText = "";
        IsAdviceLoading = true;

        try
        {
            var result = await GeminiAdvice.GetAdviceAsync(CurrentQuestion);
            if (!result.Success)
            {
                AdviceError = result.ErrorMessage ?? "Gemini advice is unavailable right now.";
                return;
            }

            AdviceText = result.Advice;
        }
        finally
        {
            IsAdviceLoading = false;
        }
    }

    // אישור משתמש לפני יציאה באמצע משחק
    private async Task<bool> ConfirmExitIfInProgressAsync()
    {
        if (CurrentQuestion is null)
            return true;

        return await JS.InvokeAsync<bool>(
            "confirm",
            "Leaving now means your XP from this game won't be saved. Continue?");
    }

    // חזרה ללובי (עם אישור יציאה אם צריך)
    // #groups #lobby: returns the player to the lobby screen.
    private async Task GoToLobbyAsync()
    {
        if (!await ConfirmExitIfInProgressAsync())
            return;

        SafeNavigateTo($"/lobby/{RoomCode}", true);
    }

    // יציאה למסך מתאים בהתאם לסוג המשחק
    // #results #menu: leaves the active game flow and returns to the main menu.
    private async Task ExitToMenuAsync()
    {
        if (!await ConfirmExitIfInProgressAsync())
            return;

        if (IsSinglePlayer)
            SafeNavigateTo($"/lobby/{RoomCode}", true);
        else
            SafeNavigateTo("/menu", true);
    }

    // שחרור טיימרים וחיבור Hub כשעוזבים את העמוד
    public async ValueTask DisposeAsync()
    {
        _disposing = true;
        heartbeatTimer?.Dispose();
        autoAdvanceTimer?.Dispose();
        countdownTimer?.Dispose();
        questionTimer?.Dispose();
        if (hub is not null)
        {
            try { await hub.InvokeAsync("LeaveRoomGroup", RoomCode); } catch { }
            try { await hub.StopAsync(); } catch { }
            await hub.DisposeAsync();
        }
    }

    private void SafeNavigateTo(string url, bool forceLoad)
    {
        if (_disposing)
            return;

        try
        {
            Nav.NavigateTo(url, forceLoad);
        }
        catch (JSDisconnectedException)
        {
            // Circuit disconnected while navigating; ignore during teardown.
        }
        catch (InvalidOperationException ex) when (ex.Message.Contains("disconnected", StringComparison.OrdinalIgnoreCase))
        {
            // Same scenario surfaced as InvalidOperationException in some flows.
        }
    }
}















