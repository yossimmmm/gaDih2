@page "/menu"
@inherits AuthPageBase
@using Models
@using DBL
@rendermode InteractiveServer

@* #menu #play #create-room #rooms #results #statistics #top-players *@
@* זהו מסך הניווט הראשי: ממנו נכנסים למשחק, לחדרים, לסטטיסטיקות ולחשבון. *@
@* מסך התפריט המרכזי: ממנו נכנסים לזרימת המשחק, לחדרים, לסטטיסטיקות ולדירוג. *@

<style>
    .menu-wrap {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: stretch;
        background: radial-gradient(1200px 800px at 10% 10%, rgba(255, 182, 193, 0.45), transparent 60%),
                    radial-gradient(900px 700px at 90% 20%, rgba(255, 105, 180, 0.35), transparent 55%),
                    linear-gradient(135deg, #ff9a9e 0%, #fecfef 25%, #fecfef 50%, #fad0c4 75%, #ffd1ff 100%);
        background-attachment: fixed;
        color: #333;
        font-family: 'Comic Neue', cursive;
        padding: 24px;
    }
    .menu-grid { width: 100%; max-width: 1100px; display: grid; grid-template-columns: 2fr 1.2fr; gap: 24px; align-items: stretch; }
    .panel { background: linear-gradient(135deg, rgba(255,255,255,.95) 0%, rgba(255,240,245,.95) 100%); border: 4px solid #ff69b4; border-radius: 24px; padding: 24px; box-shadow: 0 15px 40px rgba(255,20,147,.30), 0 0 50px rgba(255,182,193,.22); backdrop-filter: blur(8px); display: flex; flex-direction: column; gap: 14px; }
    .hero { grid-column: 1 / -1; display: grid; grid-template-columns: 1fr 1fr; gap: 16px; align-items: center; }
    .hero-title { font-size: 2.4rem; font-family: 'Fredoka One', cursive; color: #ff1493; text-shadow: 3px 3px 0 #ff69b4, 6px 6px 10px rgba(255,20,147,.35); margin-bottom: 6px; }
    .hero-sub { opacity: .85; font-weight: 700; color: #666; }
    .pill { display: inline-flex; align-items: center; gap: 8px; padding: 8px 12px; border-radius: 999px; border: 2px dashed #ff69b4; background: rgba(255,182,193,.25); font-weight: 700; color: #ff1493; }
    .panel-title { font-size: 1.45rem; font-family: 'Fredoka One', cursive; color: #ff1493; }
    .menu-btn { width: 100%; padding: 14px; border-radius: 18px; border: 3px solid #ff1493; cursor: pointer; font-family: 'Fredoka One', cursive; font-weight: 700; font-size: 1.05em; background: linear-gradient(135deg,#ff6b9d 0%,#ff8fab 50%,#ffa8c5 100%); color: #fff; letter-spacing: .5px; box-shadow: 0 8px 20px rgba(255,20,147,.35); transition: all .2s ease; }
    .menu-btn.alt { background: rgba(255,182,193,.25); color: #ff1493; border-style: dashed; }
    .menu-btn:hover { transform: translateY(-3px); box-shadow: 0 12px 28px rgba(255,20,147,.42); }
    .menu-btn:disabled { opacity: .65; cursor: not-allowed; transform: none !important; }
    .section-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
    .status { color: #c2185b; font-weight: 700; }
    @@media (max-width: 900px) {
        .menu-grid { grid-template-columns: 1fr; }
        .hero { grid-template-columns: 1fr; }
        .section-grid { grid-template-columns: 1fr; }
    }
</style>

@if (Session.CurrentUserId is null)
{
    <div>Loading...</div>
}
else
{
    <div class="menu-wrap">
        <div class="menu-grid">
            <div class="panel hero">
                <div>
                    <div class="hero-title">Trivia Game</div>
                    <div class="hero-sub">Pick a topic, start a room, and race the clock.</div>
                </div>
                <div style="display:flex;flex-direction:column;gap:10px;align-items:flex-end;">
                    <span class="pill">User: @Session.CurrentUserId | Role: @Session.CurrentRole</span>
                    @if (!string.IsNullOrWhiteSpace(Status))
                    {
                        <div class="status">@Status</div>
                    }
                </div>
            </div>

            <div class="panel">
                <div class="panel-title">Games</div>
                @* כאן בוחרים אם לשחק לבד, להצטרף לחדר קיים או ליצור חדר חדש. *@
                <select class="menu-btn alt" @bind="SelectedTopicId">
                    <option value="">All topics</option>
                    @foreach (var t in Topics)
                    {
                        <option value="@t.QuestionTypeID">@t.TypeName</option>
                    }
                </select>
                <button class="menu-btn" @onclick="StartSinglePlayer" disabled="@IsStarting">
                    @(IsStarting ? "Starting..." : "Play Alone")
                </button>
                <div class="section-grid">
                    @* מעבר למסך החדרים הציבוריים. *@
                    <button class="menu-btn" @onclick="@(() => Nav.NavigateTo("/rooms"))">Join a Room</button>
                    @* יצירת חדר חדש לפני תחילת המשחק. *@
                    <button class="menu-btn" @onclick="@(() => Nav.NavigateTo("/create-room"))">Create Room</button>
                </div>
            </div>

            <div class="panel">
                <div class="panel-title">Account</div>
                @* קיצורי הדרך לכל מה שקשור לחשבון, סטטיסטיקות וניהול. *@
                <div class="section-grid">
                    @* המסך של העוזר החכם האישי. *@
                    <button class="menu-btn" @onclick="@(() => Nav.NavigateTo("/assistant"))">My AI Assistant</button>
                    @* פירוט המשחקים והביצועים של המשתמש. *@
                    <button class="menu-btn" @onclick="@(() => Nav.NavigateTo("/stats"))">My Stats</button>
                    @* טבלת השחקנים המובילים במערכת. *@
                    <button class="menu-btn" @onclick="@(() => Nav.NavigateTo("/top-players"))">Top Players</button>
                    @* כרטיס המשתמש והפרטים שלו. *@
                    <button class="menu-btn" @onclick="@(() => Nav.NavigateTo("/user"))">My Account</button>
                </div>
                <div class="section-grid">
                    @if (IsAdmin)
                    {
                        @* מסך ניהול משתמשים זמין רק לאדמין. *@
                        <button class="menu-btn" @onclick="@(() => Nav.NavigateTo("/admin-users"))">Admin Users</button>
                    }
                    @* יציאה מהמערכת ומחיקת הסשן. *@
                    <button class="menu-btn alt" @onclick="Logout">Logout</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private readonly RoomDB roomDB = new();
    private readonly GameDB gameDB = new();
    private readonly QuestionTypeDB questionTypeDB = new();
    private string Status = "";
    private bool IsStarting;
    private List<QuestionType> Topics = new();
    private int? SelectedTopicId;
    // רק אדמין רואה את מסך הניהול.
    private bool IsAdmin => Session.CurrentRole == UserRole.Admin;

    // #solo-game #play: creates a private room, picks questions, and starts the solo flow.
    private async Task StartSinglePlayer()
    {
        if (Session.CurrentUserId is null || IsStarting)
            return;

        IsStarting = true;
        Status = "Creating single player game...";
        try
        {
            // יוצרים חדר פרטי למשחק יחיד, עם נושא אופציונלי אם המשתמש בחר סינון.
            var room = await roomDB.CreateRoomAsync($"Single Player - {DateTime.Now:HH:mm}", Session.CurrentUserId.Value, false, SelectedTopicId);
            if (room is null) { Status = "Failed to create room."; return; }
            // השחקן עדיין נרשם לחדר כמו כל שחקן אחר כדי לקבל RoomPlayerId ותשתית משחק.
            await roomDB.JoinRoomAsync(room.RoomID, Session.CurrentUserId.Value, "You");
            // טוענים שאלות לחדר כדי שהמסך הבא יוכל להתחיל מיד.
            var count = await gameDB.PickQuestionsForRoomAsync(room.RoomID, 10);
            if (count == 0) { Status = "No questions available."; return; }
            // מעבר למסך המשחק עצמו.
            Nav.NavigateTo($"/play/{room.RoomCode}", true);
        }
        catch (Exception ex)
        {
            Status = ex.Message;
        }
        finally
        {
            IsStarting = false;
        }
    }

    // #logout #cookie: signs the user out and clears the session.
    private async Task Logout()
    {
        // מאפסים את מצב המשתמש המקומי לפני מחיקת הקוקי.
        Session.CurrentUserId = null;
        Session.CurrentRole = UserRole.User;
        // ה-JS מוחק את ה-session cookie בצד הדפדפן.
        await JS.InvokeVoidAsync("auth.logout");
        // אחרי היציאה חוזרים למסך הכניסה.
        Nav.NavigateTo("/login", true);
    }

    // #menu: loads question topics and prepares the main navigation screen.
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        // טוענים את סוגי השאלות כדי לאפשר סינון למשחק לבד.
        Topics = await questionTypeDB.GetAllAsync();
    }
}
