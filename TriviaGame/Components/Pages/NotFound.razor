@page "/not-found"
@layout MainLayout

<style>
    .notfound-wrap {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 25%, #fecfef 50%, #fad0c4 75%, #ffd1ff 100%);
        background-attachment: fixed;
        color: #333;
        font-family: 'Comic Neue', cursive;
        position: relative;
        overflow: hidden;
        padding: 20px;
    }
    
    .notfound-wrap::before {
        content: "🔍";
        position: absolute;
        font-size: 6em;
        animation: float 3s ease-in-out infinite;
        top: 10%;
        left: 10%;
        opacity: 0.6;
    }
    
    .notfound-wrap::after {
        content: "❓";
        position: absolute;
        font-size: 5em;
        animation: float 4s ease-in-out infinite reverse;
        top: 20%;
        right: 15%;
        opacity: 0.5;
    }
    
    .notfound-card {
        width: 500px;
        max-width: 95%;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(255, 240, 245, 0.95));
        border: 5px solid #ffb6c1;
        border-radius: 35px;
        padding: 50px;
        box-shadow: 0 15px 40px rgba(255, 182, 193, 0.5), 0 0 60px rgba(255, 182, 193, 0.4);
        position: relative;
        z-index: 1;
        animation: pulse-glow 3s ease-in-out infinite;
        text-align: center;
    }
    
    .notfound-card::before {
        content: "📍";
        position: absolute;
        top: -30px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 4em;
        animation: bounce 2s infinite;
        z-index: -1;
    }
    
    .notfound-title {
        font-family: 'Fredoka One', cursive;
        font-size: 3.5rem;
        color: #ff1493;
        text-shadow: 3px 3px 0px #ff69b4, 6px 6px 10px rgba(255, 20, 147, 0.4);
        margin-bottom: 20px;
        animation: float 2s ease-in-out infinite;
    }
    
    .notfound-text {
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.4em;
        color: #666;
        line-height: 1.6;
        margin-top: 20px;
    }
</style>

@* מעטפת עמוד 404 שמוצג כאשר הנתיב לא קיים במערכת *@
<div class="notfound-wrap">
    @* כרטיס מרכזי עם הודעת שגיאה ידידותית למשתמש *@
    <div class="notfound-card">
        @* כותרת שגיאה סטנדרטית של HTTP 404 *@
        <div class="notfound-title">@TitleText</div>
        @* תיאור קצר שמסביר שהעמוד המבוקש לא נמצא *@
        <div class="notfound-text">@DescriptionText</div>

    </div>
</div>

@code {
    // טקסט כותרת קבוע למסך 404
    private const string TitleText = "🔍 404 Not Found";
    // תיאור ידידותי למשתמש כשעמוד לא קיים
    private const string DescriptionText = "Oops! 😅 The page you're looking for doesn't exist in our cartoon world! 🎨";
}
