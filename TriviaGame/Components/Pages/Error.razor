@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<style>
    .error-wrap {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 25%, #fecfef 50%, #fad0c4 75%, #ffd1ff 100%);
        background-attachment: fixed;
        color: #333;
        font-family: 'Comic Neue', cursive;
        position: relative;
        overflow: hidden;
        padding: 20px;
    }
    
    .error-wrap::before {
        content: "⚠️";
        position: absolute;
        font-size: 6em;
        animation: bounce 2s infinite;
        top: 10%;
        left: 10%;
        opacity: 0.6;
    }
    
    .error-card {
        width: 600px;
        max-width: 95%;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(255, 240, 245, 0.95));
        border: 5px solid #ff4757;
        border-radius: 35px;
        padding: 40px;
        box-shadow: 0 15px 40px rgba(255, 71, 87, 0.5), 0 0 60px rgba(255, 182, 193, 0.4);
        position: relative;
        z-index: 1;
        animation: wiggle 0.5s ease, pulse-glow 2s ease-in-out infinite;
    }
    
    .error-title {
        font-family: 'Fredoka One', cursive;
        font-size: 3rem;
        color: #ff4757;
        text-shadow: 3px 3px 0px #ff6b6b, 6px 6px 10px rgba(255, 71, 87, 0.5);
        margin-bottom: 20px;
        animation: float 2s ease-in-out infinite;
    }
    
    .error-subtitle {
        font-family: 'Fredoka One', cursive;
        font-size: 1.8rem;
        color: #ff6b6b;
        text-shadow: 2px 2px 4px rgba(255, 107, 107, 0.4);
        margin-bottom: 20px;
    }
    
    .error-text {
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.1em;
        color: #666;
        margin: 15px 0;
        line-height: 1.6;
    }
    
    .error-code {
        background: rgba(255, 182, 193, 0.3);
        padding: 10px 15px;
        border-radius: 15px;
        border: 2px dashed #ff69b4;
        font-family: 'Comic Neue', cursive;
        font-weight: 700;
        font-size: 1.1em;
        color: #ff1493;
        margin: 10px 0;
        display: inline-block;
    }
</style>

<div class="error-wrap">
    <div class="error-card">
        @* כותרת ראשית של מסך השגיאה *@
        <div class="error-title">🎭 Oops! Error</div>
        @* כותרת משנה שמסבירה שהייתה תקלה כללית *@
        <div class="error-subtitle">Something went wrong! 😅</div>
        
        @* בלוק מותנה: מוצג רק אם הצלחנו לזהות RequestId *@
        @if (ShowRequestId)
        {
            <div class="error-text">
                <strong>Request ID:</strong> 
                @* מזהה הבקשה עוזר בדיבוג שרת ולמצוא את התקלה בלוגים *@
                <span class="error-code">@RequestId</span>
            </div>
        }

        @* מידע למפתח על מצב Development ולמה לא להפעיל אותו בפרודקשן *@
        <div class="error-text">
            <h3 style="color: #ff1493; font-family: 'Fredoka One', cursive;">🔧 Development Mode</h3>
            <p>
                Swapping to <strong>Development</strong> environment will display more detailed information about the error that occurred.
            </p>
            <p>
                <strong>⚠️ The Development environment shouldn't be enabled for deployed applications.</strong>
                It can result in displaying sensitive information from exceptions to end users.
                For local debugging, enable the <strong>Development</strong> environment by setting the <strong>ASPNETCORE_ENVIRONMENT</strong> environment variable to <strong>Development</strong>
                and restarting the app.
            </p>
        </div>

    </div>
</div>

@code {
    // הסבר עמוד: לוגיקת Error וניהול מצב המסך.
    // HttpContext מגיע כ-CascadingParameter מהתשתית של Blazor/ASP.NET.
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    // מזהה בקשה נוכחי (אם קיים) לצורך דיבוג.
    private string? RequestId { get; set; }
    // האם יש RequestId להצגה ב-UI.
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    // רץ בזמן אתחול העמוד ומנסה להביא מזהה בקשה משני מקורות:
    // 1) Activity.Current (trace פעיל), 2) HttpContext.TraceIdentifier.
    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;

}



