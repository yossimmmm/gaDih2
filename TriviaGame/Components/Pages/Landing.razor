@page "/"
@inject NavigationManager Nav
@rendermode InteractiveServer

<style>
    .wrap {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 25%, #fecfef 50%, #fad0c4 75%, #ffd1ff 100%);
        background-attachment: fixed;
        color: #333;
        font-family: 'Comic Neue', cursive;
        position: relative;
        overflow: hidden;
        padding: 20px;
    }

    .card {
        width: 720px;
        max-width: 95%;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 240, 245, 0.95) 100%);
        border: 5px solid #ff69b4;
        border-radius: 35px;
        padding: 40px;
        box-shadow: 0 15px 40px rgba(255, 20, 147, 0.4), 0 0 60px rgba(255, 182, 193, 0.3);
        backdrop-filter: blur(10px);
        position: relative;
        z-index: 1;
        animation: pulse-glow 3s ease-in-out infinite;
        transform-style: preserve-3d;
        text-align: center;
    }

    .title {
        font-size: 2.6rem;
        font-family: 'Fredoka One', cursive;
        color: #ff1493;
        text-shadow: 3px 3px 0px #ff69b4, 6px 6px 10px rgba(255, 20, 147, 0.4);
        margin-bottom: 10px;
        letter-spacing: 2px;
    }

    .sub {
        font-size: 1.2em;
        font-weight: 700;
        color: #666;
        margin-bottom: 20px;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
        margin: 20px 0;
        text-align: left;
    }

    .feature {
        padding: 16px;
        border-radius: 20px;
        background: rgba(255, 240, 245, 0.7);
        border: 3px dashed #ffb6c1;
        font-weight: 700;
    }

    .btn {
        width: 100%;
        padding: 16px;
        border: 4px solid #ff1493;
        border-radius: 25px;
        background: linear-gradient(135deg, #ff6b9d 0%, #ff8fab 50%, #ffa8c5 100%);
        color: #fff;
        font-family: 'Fredoka One', cursive;
        font-weight: 700;
        font-size: 1.1em;
        margin-top: 10px;
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 2px;
        box-shadow: 0 8px 20px rgba(255, 20, 147, 0.4);
        transition: all 0.3s ease;
    }

    .btn2 {
        width: 100%;
        padding: 16px;
        border-radius: 25px;
        border: 4px solid #ffb6c1;
        cursor: pointer;
        font-family: 'Fredoka One', cursive;
        font-weight: 700;
        font-size: 1.1em;
        background: rgba(255, 182, 193, 0.3);
        color: #ff1493;
        text-transform: uppercase;
        letter-spacing: 2px;
        box-shadow: 0 5px 15px rgba(255, 182, 193, 0.4);
        transition: all 0.3s ease;
        margin-top: 10px;
    }

    @@media (max-width: 480px) {
        .wrap {
            padding: 10px;
            align-items: flex-start;
        }

        .card {
            width: 100%;
            max-width: none;
            border-radius: 22px;
            padding: 20px 14px;
            margin-top: 8px;
        }

        .title {
            font-size: 2rem;
            letter-spacing: 1px;
        }

        .sub {
            font-size: 1.05rem;
            margin-bottom: 14px;
        }

        .grid {
            grid-template-columns: 1fr;
            gap: 10px;
            margin: 14px 0;
        }

        .feature {
            padding: 12px;
            border-radius: 14px;
        }

        .btn,
        .btn2 {
            padding: 13px;
            font-size: 1rem;
        }
    }
</style>

@* מעטפת ראשית של עמוד הנחיתה *@
<div class="wrap">
    @* כרטיס מרכזי שמכיל את התוכן הראשי והפעולות *@
    <div class="card">
        @* כותרת מוצר/משחק *@
        <div class="title">🎯 Trivia Game</div>
        @* משפט קצר שמסביר את ערך המשחק *@
        <div class="sub">Play solo or with friends, pick your topics, and race the clock.</div>

        @* רשת יכולות עיקריות שהמשתמש רואה לפני הרשמה/לוגין *@
        <div class="grid">
            <div class="feature">⚡ 15-second timed questions for real-time multiplayer.</div>
            <div class="feature">🎮 Play alone with your favorite topic.</div>
            <div class="feature">🌍 Public rooms so anyone can join instantly.</div>
            <div class="feature">🏆 Results, stats, and top players leaderboard.</div>
        </div>

        @* כפתור Login: ניווט למסך התחברות עם רענון מלא *@
        <button class="btn" @onclick="@(() => Nav.NavigateTo("/login", true))" title="Go to login page">Login</button>
        @* כפתור Create Account: ניווט למסך הרשמה עם רענון מלא *@
        <button class="btn2" @onclick="@(() => Nav.NavigateTo("/register", true))" title="Go to registration page">Create Account</button>

    </div>
</div>
