@page "/stats"
@inherits AuthPageBase
@using Models
@using DBL
@rendermode InteractiveServer

@* #statistics #stats #my-stats #games-played #wins #correct-answers *@
@* מסך הסטטיסטיקות האישיות: כאן רואים נתונים מצטברים על המשתמש לאורך זמן. *@

<style>
    .wrap { min-height: 100vh; display: flex; justify-content: center; align-items: center; background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 25%, #fecfef 50%, #fad0c4 75%, #ffd1ff 100%); background-attachment: fixed; color: #333; font-family: 'Comic Neue', cursive; position: relative; overflow: hidden; padding: 20px; }
    .card { width: 620px; max-width: 95%; background: linear-gradient(135deg, rgba(255,255,255,.95) 0%, rgba(255,240,245,.95) 100%); border: 5px solid #ff69b4; border-radius: 35px; padding: 40px; box-shadow: 0 15px 40px rgba(255,20,147,.4), 0 0 60px rgba(255,182,193,.3); backdrop-filter: blur(10px); position: relative; z-index: 1; animation: pulse-glow 3s ease-in-out infinite; transform-style: preserve-3d; }
    .title { font-size: 2.3rem; font-family: 'Fredoka One', cursive; color: #ff1493; text-shadow: 3px 3px 0 #ff69b4, 6px 6px 10px rgba(255,20,147,.4); margin-bottom: 10px; letter-spacing: 2px; text-align: center; }
    .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; margin-top: 20px; }
    .stat { padding: 16px; border-radius: 20px; background: rgba(255,240,245,.7); border: 3px dashed #ffb6c1; text-align: center; font-weight: 700; }
    .stat-title { font-size: .95em; opacity: .8; margin-bottom: 6px; }
    .stat-value { font-size: 1.6em; color: #ff1493; font-family: 'Fredoka One', cursive; }
    .btn2 { width: 100%; padding: 14px; border-radius: 25px; border: 4px solid #ffb6c1; cursor: pointer; font-family: 'Fredoka One', cursive; font-weight: 700; font-size: 1.1em; background: rgba(255,182,193,.3); color: #ff1493; text-transform: uppercase; letter-spacing: 2px; box-shadow: 0 5px 15px rgba(255,182,193,.4); transition: all .3s ease; margin-top: 20px; }
</style>

@* אם המשתמש לא מאומת עדיין, מציגים מסך טעינה *@
@if (Session.CurrentUserId is null)
{
    <div class="wrap"><div class="card">Loading...</div></div>
}
else
{
    <div class="wrap">
        <div class="card">
            @* כותרת עמוד סטטיסטיקות *@
            <div class="title">My Stats</div>

            @* גריד מדדים: כל תא מציג KPI אישי של המשתמש *@
            <div class="grid">
                <div class="stat">
                    <div class="stat-title">Games Played</div>
                    <div class="stat-value">@GamesPlayed</div>
                </div>
                <div class="stat">
                    <div class="stat-title">Wins</div>
                    <div class="stat-value">@Wins</div>
                </div>
                <div class="stat">
                    <div class="stat-title">Correct Answers</div>
                    <div class="stat-value">@CorrectAnswers</div>
                </div>
                <div class="stat">
                    <div class="stat-title">Total Answers</div>
                    <div class="stat-value">@TotalAnswers</div>
                </div>
            </div>

            @* כפתור חזרה לתפריט הראשי *@
            <button class="btn2" @onclick="@(() => Nav.NavigateTo("/menu", true))">Back to Menu</button>

        </div>
    </div>
}

@code {
    // הסבר עמוד: טעינה והצגה של נתוני ביצועי המשתמש מהמסד.
    private int GamesPlayed = 0; // כמה משחקים המשתמש שיחק
    private int Wins = 0; // כמה ניצחונות למשתמש
    private int CorrectAnswers = 0; // כמות תשובות נכונות
    private int TotalAnswers = 0; // כמות תשובות כוללת

    private readonly GameDB gameDB = new(); // DB משחקים וסטטיסטיקות
    private bool Loaded = false; // מניעת טעינה כפולה

    // נטען אחרי אימות משתמש ומביא את הסטטיסטיקות פעם אחת.
    // #statistics: loads the current user's cumulative stats from the database.
    protected override async Task OnAuthedAsync()
    {
        if (Loaded)
            return;
        Loaded = true;

        var stats = await gameDB.GetUserStatsAsync(Session.CurrentUserId.Value);
        GamesPlayed = stats.GamesPlayed;
        Wins = stats.Wins;
        CorrectAnswers = stats.Correct;
        TotalAnswers = stats.Answered;
    }
}
